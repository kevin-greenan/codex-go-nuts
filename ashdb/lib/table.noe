& "table_leaf.noe";

%Table {
    pager: Pager;
    root_page: i64;
    slot_width: i64;
}

@table_internal_count_width() -> i64 {
    ^ 8;
}

@table_internal_child_width() -> i64 {
    ^ 8;
}

@table_internal_key_width() -> i64 {
    ^ 8;
}

@table_internal_cell_width() -> i64 {
    ^ table_internal_key_width() + table_internal_child_width();
}

@table_internal_header_size() -> i64 {
    ^ 1 + table_internal_count_width() + table_internal_child_width();
}

@table_internal_capacity(page_size: i64) -> i64 {
    ^ (page_size - 1 - table_internal_header_size()) / table_internal_cell_width();
}

@table_internal_page_text(page_size: i64, key_count: i64, left_child: i64, cells: text) -> text {
    body := "I" + pad_left_i64(key_count, table_internal_count_width()) + pad_left_i64(left_child, table_internal_child_width()) + cells;
    max_body := page_size - 1;
    ^ pad_right(body, max_body, ".");
}

@table_internal_empty_cell() -> text {
    ^ repeat_unit(".", table_internal_cell_width());
}

@table_internal_build_cells(capacity: i64, used_cells: text, key_count: i64) -> text {
    ^ used_cells + repeat_unit(table_internal_empty_cell(), capacity - key_count);
}

@table_internal_key_count(page: text) -> i64 {
    ^ i64_of(slice(page, 2, table_internal_count_width()));
}

@table_internal_left_child(page: text) -> i64 {
    ^ i64_of(slice(page, 2 + table_internal_count_width(), table_internal_child_width()));
}

@table_internal_used_cells(page: text) -> text {
    key_count := table_internal_key_count(page);
    start := 1 + table_internal_header_size();
    cells := slice(page, start, count(page) - start);
    ^ slice(cells, 0, key_count * table_internal_cell_width());
}

@table_internal_cell_text(key: i64, right_child: i64) -> text {
    ^ pad_left_i64(key, table_internal_key_width()) + pad_left_i64(right_child, table_internal_child_width());
}

@table_internal_cell_at(cells: text, cell_index: i64) -> text {
    ^ slice(cells, cell_index * table_internal_cell_width(), table_internal_cell_width());
}

@table_internal_cell_key(cell: text) -> i64 {
    ^ i64_of(slice(cell, 0, table_internal_key_width()));
}

@table_internal_cell_child(cell: text) -> i64 {
    ^ i64_of(slice(cell, table_internal_key_width(), table_internal_child_width()));
}

@table_internal_insert_used(used_cells: text, key_count: i64, cell_index: i64, cell_text: text) -> text {
    prefix := slice(used_cells, 0, cell_index * table_internal_cell_width());
    moved := slice(used_cells, cell_index * table_internal_cell_width(), (key_count - cell_index) * table_internal_cell_width());
    ^ prefix + cell_text + moved;
}

@table_internal_find_insert_index_in_page(table: Table, page_id: i64, key: i64) -> i64 {
    page := pager_read_page(table.pager, page_id);
    key_count := table_internal_key_count(page);
    used_cells := table_internal_used_cells(page);
    cell_index := 0;
    ~ (cell_index < key_count) {
        cell := table_internal_cell_at(used_cells, cell_index);
        ? (table_internal_cell_key(cell) >= key) {
            ^ cell_index;
        }
        cell_index = cell_index + 1;
    }
    ^ key_count;
}

@table_internal_find_insert_index(table: Table, key: i64) -> i64 {
    ^ table_internal_find_insert_index_in_page(table, table.root_page, key);
}

@table_internal_init_page(table: Table, page_id: i64, left_child: i64) -> i64 {
    capacity := table_internal_capacity(table.pager.page_size);
    cells := table_internal_build_cells(capacity, "", 0);
    ^ pager_write_page(table.pager, page_id, table_internal_page_text(table.pager.page_size, 0, left_child, cells));
}

@table_internal_init_root(table: Table, left_child: i64) -> i64 {
    ^ table_internal_init_page(table, table.root_page, left_child);
}

@table_internal_insert_separator_in_page(table: Table, page_id: i64, key: i64, right_child: i64) -> i64 {
    page := pager_read_page(table.pager, page_id);
    key_count := table_internal_key_count(page);
    capacity := table_internal_capacity(table.pager.page_size);
    left_child := table_internal_left_child(page);
    used_cells := table_internal_used_cells(page);
    insert_index := table_internal_find_insert_index_in_page(table, page_id, key);
    ? (insert_index < key_count) {
        existing := table_internal_cell_at(used_cells, insert_index);
        ? (table_internal_cell_key(existing) == key) {
            ^ -2;
        }
    }
    ? (key_count >= capacity) {
        ^ -1;
    }
    updated_used := table_internal_insert_used(used_cells, key_count, insert_index, table_internal_cell_text(key, right_child));
    updated_cells := table_internal_build_cells(capacity, updated_used, key_count + 1);
    wrote := pager_write_page(table.pager, page_id, table_internal_page_text(table.pager.page_size, key_count + 1, left_child, updated_cells));
    ? (wrote == table.pager.page_size) {
        ^ insert_index;
    }
    ^ -1;
}

@table_internal_insert_separator(table: Table, key: i64, right_child: i64) -> i64 {
    ^ table_internal_insert_separator_in_page(table, table.root_page, key, right_child);
}

@table_internal_child_for_key_in_page(table: Table, page_id: i64, key: i64) -> i64 {
    page := pager_read_page(table.pager, page_id);
    key_count := table_internal_key_count(page);
    child := table_internal_left_child(page);
    used_cells := table_internal_used_cells(page);
    cell_index := 0;
    ~ (cell_index < key_count) {
        cell := table_internal_cell_at(used_cells, cell_index);
        ? (key < table_internal_cell_key(cell)) {
            ^ child;
        }
        child = table_internal_cell_child(cell);
        cell_index = cell_index + 1;
    }
    ^ child;
}

@table_internal_child_for_key(table: Table, key: i64) -> i64 {
    ^ table_internal_child_for_key_in_page(table, table.root_page, key);
}

@table_internal_result_ok() -> text {
    ^ "ok";
}

@table_internal_result_err(code: i64) -> text {
    ^ "err:" + text_of(code);
}

@table_internal_result_split(separator_key: i64, right_page: i64) -> text {
    ^ "split:" + text_of(separator_key) + ":" + text_of(right_page);
}

@table_internal_result_is_split(result: text) -> bool {
    ^ count(result) >= 6 and slice(result, 0, 6) == "split:";
}

@table_internal_result_separator(result: text) -> i64 {
    first_colon := find(result, ":");
    rest := slice(result, first_colon + 1, count(result) - (first_colon + 1));
    second_colon := find(rest, ":");
    ^ i64_of(slice(rest, 0, second_colon));
}

@table_internal_result_right_page(result: text) -> i64 {
    first_colon := find(result, ":");
    rest := slice(result, first_colon + 1, count(result) - (first_colon + 1));
    second_colon := find(rest, ":");
    right_text := slice(rest, second_colon + 1, count(rest) - (second_colon + 1));
    ^ i64_of(right_text);
}

@table_internal_used_delete_cell(used_cells: text, key_count: i64, cell_index: i64) -> text {
    prefix := slice(used_cells, 0, cell_index * table_internal_cell_width());
    suffix_start := (cell_index + 1) * table_internal_cell_width();
    moved := slice(used_cells, suffix_start, (key_count - cell_index - 1) * table_internal_cell_width());
    ^ prefix + moved;
}

@table_internal_split_insert_separator_in_page(table: Table, page_id: i64, key: i64, right_child: i64) -> text {
    page := pager_read_page(table.pager, page_id);
    key_count := table_internal_key_count(page);
    capacity := table_internal_capacity(table.pager.page_size);
    left_child := table_internal_left_child(page);
    used_cells := table_internal_used_cells(page);
    insert_index := table_internal_find_insert_index_in_page(table, page_id, key);
    ? (insert_index < key_count) {
        existing := table_internal_cell_at(used_cells, insert_index);
        ? (table_internal_cell_key(existing) == key) {
            ^ table_internal_result_err(-2);
        }
    }
    ? (key_count < capacity) {
        ^ table_internal_result_err(-1);
    }
    combined_used := table_internal_insert_used(used_cells, key_count, insert_index, table_internal_cell_text(key, right_child));
    total_keys := key_count + 1;
    middle_index := total_keys / 2;
    separator_cell := table_internal_cell_at(combined_used, middle_index);
    separator_key := table_internal_cell_key(separator_cell);
    right_left_child := table_internal_cell_child(separator_cell);
    left_used := slice(combined_used, 0, middle_index * table_internal_cell_width());
    right_used_start := (middle_index + 1) * table_internal_cell_width();
    right_used_count := total_keys - middle_index - 1;
    right_used := slice(combined_used, right_used_start, right_used_count * table_internal_cell_width());
    right_page := pager_alloc_page(table.pager);
    left_cells := table_internal_build_cells(capacity, left_used, middle_index);
    right_cells := table_internal_build_cells(capacity, right_used, right_used_count);
    left_write := pager_write_page(table.pager, page_id, table_internal_page_text(table.pager.page_size, middle_index, left_child, left_cells));
    right_write := pager_write_page(table.pager, right_page, table_internal_page_text(table.pager.page_size, right_used_count, right_left_child, right_cells));
    ? (left_write == table.pager.page_size and right_write == table.pager.page_size) {
        ^ table_internal_result_split(separator_key, right_page);
    }
    ^ table_internal_result_err(-3);
}

@table_page_kind(table: Table, page_id: i64) -> text {
    page := pager_read_page(table.pager, page_id);
    ^ slice(page, 1, 1);
}

@table_root_page() -> i64 {
    ^ 1;
}

@table_bind(pager: Pager, root_page: i64, slot_width: i64) -> Table {
    ^ Table { pager: pager, root_page: root_page, slot_width: slot_width };
}

@table_open(path: text, page_size: i64, slot_width: i64) -> Table {
    pager := pager_open(path, page_size);
    total_pages := pager_total_pages(pager);
    root_page := table_root_page();
    ? (total_pages == 1) {
        allocated := pager_alloc_page(pager);
        initialized := leaf_init_page(pager, root_page, slot_width);
    }
    ^ table_bind(pager, root_page, slot_width);
}

@table_root_kind(table: Table) -> text {
    ^ table_page_kind(table, table.root_page);
}

@table_promote_root_split(table: Table, separator_key: i64, right_page: i64) -> i64 {
    left_page := pager_alloc_page(table.pager);
    left_text := pager_read_page(table.pager, table.root_page);
    left_copy := pager_raw_write_page(table.pager, left_page, left_text);
    root_init := table_internal_init_root(table, left_page);
    inserted := table_internal_insert_separator(table, separator_key, right_page);
    ? (left_copy == table.pager.page_size and root_init == table.pager.page_size and inserted >= 0) {
        ^ 0;
    }
    ^ -3;
}

@table_insert_page(table: Table, page_id: i64, key: i64, payload: text) -> text {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        wrote := leaf_insert_key(table.pager, page_id, key, payload);
        ? (wrote >= 0) {
            ^ table_internal_result_ok();
        }
        ? (wrote == -1) {
            split_right := leaf_split_insert_key(table.pager, page_id, key, payload);
            ? (split_right >= 0) {
                separator_key := leaf_first_key(table.pager, split_right);
                ^ table_internal_result_split(separator_key, split_right);
            }
        }
        ^ table_internal_result_err(wrote);
    }
    ? (page_kind == "I") {
        child_page := table_internal_child_for_key_in_page(table, page_id, key);
        child_result := table_insert_page(table, child_page, key, payload);
        ? (child_result == "ok") {
            ^ child_result;
        }
        ? (table_internal_result_is_split(child_result)) {
            separator_key := table_internal_result_separator(child_result);
            split_right := table_internal_result_right_page(child_result);
            inserted := table_internal_insert_separator_in_page(table, page_id, separator_key, split_right);
            ? (inserted >= 0) {
                ^ table_internal_result_ok();
            }
            ? (inserted == -1) {
                ^ table_internal_split_insert_separator_in_page(table, page_id, separator_key, split_right);
            }
            ^ table_internal_result_err(inserted);
        }
        ^ child_result;
    }
    ^ table_internal_result_err(-5);
}

@table_insert(table: Table, key: i64, payload: text) -> i64 {
    result := table_insert_page(table, table.root_page, key, payload);
    ? (result == "ok") {
        ^ 0;
    }
    ? (table_internal_result_is_split(result)) {
        separator_key := table_internal_result_separator(result);
        right_page := table_internal_result_right_page(result);
        ^ table_promote_root_split(table, separator_key, right_page);
    }
    first_colon := find(result, ":");
    ? (first_colon >= 0) {
        code_text := slice(result, first_colon + 1, count(result) - (first_colon + 1));
        ^ i64_of(code_text);
    }
    ^ -9;
}

@table_update_page(table: Table, page_id: i64, key: i64, payload: text) -> i64 {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        ^ leaf_update_key(table.pager, page_id, key, payload);
    }
    ? (page_kind == "I") {
        child_page := table_internal_child_for_key_in_page(table, page_id, key);
        ^ table_update_page(table, child_page, key, payload);
    }
    ^ -1;
}

@table_update(table: Table, key: i64, payload: text) -> i64 {
    ^ table_update_page(table, table.root_page, key, payload);
}

@table_put_page(table: Table, page_id: i64, key: i64, payload: text) -> text {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        wrote := leaf_put_key(table.pager, page_id, key, payload);
        ? (wrote >= 0) {
            ^ table_internal_result_ok();
        }
        ? (wrote == -1) {
            split_right := leaf_split_insert_key(table.pager, page_id, key, payload);
            ? (split_right >= 0) {
                separator_key := leaf_first_key(table.pager, split_right);
                ^ table_internal_result_split(separator_key, split_right);
            }
        }
        ^ table_internal_result_err(wrote);
    }
    ? (page_kind == "I") {
        child_page := table_internal_child_for_key_in_page(table, page_id, key);
        child_result := table_put_page(table, child_page, key, payload);
        ? (child_result == "ok") {
            ^ child_result;
        }
        ? (table_internal_result_is_split(child_result)) {
            separator_key := table_internal_result_separator(child_result);
            split_right := table_internal_result_right_page(child_result);
            inserted := table_internal_insert_separator_in_page(table, page_id, separator_key, split_right);
            ? (inserted >= 0) {
                ^ table_internal_result_ok();
            }
            ? (inserted == -1) {
                ^ table_internal_split_insert_separator_in_page(table, page_id, separator_key, split_right);
            }
            ^ table_internal_result_err(inserted);
        }
        ^ child_result;
    }
    ^ table_internal_result_err(-5);
}

@table_put(table: Table, key: i64, payload: text) -> i64 {
    result := table_put_page(table, table.root_page, key, payload);
    ? (result == "ok") {
        ^ 0;
    }
    ? (table_internal_result_is_split(result)) {
        separator_key := table_internal_result_separator(result);
        right_page := table_internal_result_right_page(result);
        ^ table_promote_root_split(table, separator_key, right_page);
    }
    first_colon := find(result, ":");
    ? (first_colon >= 0) {
        code_text := slice(result, first_colon + 1, count(result) - (first_colon + 1));
        ^ i64_of(code_text);
    }
    ^ -9;
}

@table_get_page(table: Table, page_id: i64, key: i64) -> text {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        ^ leaf_read_by_key(table.pager, page_id, key);
    }
    ? (page_kind == "I") {
        child_page := table_internal_child_for_key_in_page(table, page_id, key);
        ^ table_get_page(table, child_page, key);
    }
    ^ "";
}

@table_get(table: Table, key: i64) -> text {
    ^ table_get_page(table, table.root_page, key);
}

@table_delete_page(table: Table, page_id: i64, key: i64) -> i64 {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        ^ leaf_delete_key(table.pager, page_id, key);
    }
    ? (page_kind == "I") {
        child_page := table_internal_child_for_key_in_page(table, page_id, key);
        ^ table_delete_page(table, child_page, key);
    }
    ^ -1;
}

@table_delete(table: Table, key: i64) -> i64 {
    ^ table_delete_page(table, table.root_page, key);
}

@table_scan_leaf_text(table: Table, page_id: i64, separator: text) -> text {
    page := leaf_read_page(table.pager, page_id);
    slot_count := leaf_slot_count(page);
    out := "";
    slot_index := 0;
    ~ (slot_index < slot_count) {
        value := leaf_read_slot(table.pager, page_id, slot_index);
        ? (count(value) > 0) {
            ? (count(out) > 0) {
                out = out + separator;
            }
            out = out + value;
        }
        slot_index = slot_index + 1;
    }
    ^ out;
}

@table_scan_page_text(table: Table, page_id: i64, separator: text) -> text {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        ^ table_scan_leaf_text(table, page_id, separator);
    }
    ? (page_kind == "I") {
        page := pager_read_page(table.pager, page_id);
        key_count := table_internal_key_count(page);
        used_cells := table_internal_used_cells(page);
        out := table_scan_page_text(table, table_internal_left_child(page), separator);
        cell_index := 0;
        ~ (cell_index < key_count) {
            cell := table_internal_cell_at(used_cells, cell_index);
            child_text := table_scan_page_text(table, table_internal_cell_child(cell), separator);
            ? (count(child_text) > 0) {
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + child_text;
            }
            cell_index = cell_index + 1;
        }
        ^ out;
    }
    ^ "";
}

@table_scan_text(table: Table, separator: text) -> text {
    ^ table_scan_page_text(table, table.root_page, separator);
}

@table_sync(table: Table) -> bool {
    ^ pager_sync(table.pager);
}

@table_close(table: Table) -> bool {
    ^ pager_close(table.pager);
}
