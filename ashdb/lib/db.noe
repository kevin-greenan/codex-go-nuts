& "table.noe";
& "row.noe";

%DB {
    pager: Pager;
    path: text;
}

@db_index_table_name(table_name: text, index_name: text) -> text {
    ^ "idx." + table_name + "." + index_name;
}

@db_journal_path(db: DB) -> text {
    ^ db.path + ".journal";
}

@db_journal_size_width() -> i64 {
    ^ 8;
}

@db_journal_header_size() -> i64 {
    ^ 1 + db_journal_size_width() + db_journal_size_width();
}

@db_journal_header(active: bool, original_page_count: i64, entry_count: i64) -> text {
    flag := ".";
    ? (active) {
        flag = "J";
    }
    ^ flag + pad_left_i64(original_page_count, db_journal_size_width()) + pad_left_i64(entry_count, db_journal_size_width());
}

@db_journal_active(header: text) -> bool {
    ? (count(header) < db_journal_header_size()) {
        ^ false;
    }
    ^ slice(header, 0, 1) == "J";
}

@db_journal_original_page_count(header: text) -> i64 {
    ? (count(header) < db_journal_header_size()) {
        ^ 0;
    }
    ^ i64_of(slice(header, 1, db_journal_size_width()));
}

@db_journal_entry_count(header: text) -> i64 {
    ? (count(header) < db_journal_header_size()) {
        ^ 0;
    }
    ^ i64_of(slice(header, 1 + db_journal_size_width(), db_journal_size_width()));
}

@db_journal_entry_size(page_size: i64) -> i64 {
    ^ db_journal_size_width() + page_size;
}

@db_journal_entry_offset(page_size: i64, entry_index: i64) -> i64 {
    ^ db_journal_header_size() + (entry_index * db_journal_entry_size(page_size));
}

@db_journal_entry_text(page_id: i64, page_text: text) -> text {
    ^ pad_left_i64(page_id, db_journal_size_width()) + page_text;
}

@db_journal_entry_page_id(entry_text: text) -> i64 {
    ^ i64_of(slice(entry_text, 0, db_journal_size_width()));
}

@db_journal_entry_page_text(entry_text: text, page_size: i64) -> text {
    ^ slice(entry_text, db_journal_size_width(), page_size);
}

@db_journal_clear(db: DB) -> bool {
    journal := file_open(db_journal_path(db));
    wrote := file_write(journal, 0, db_journal_header(false, 0, 0));
    synced := file_sync(journal);
    closed := file_close(journal);
    ^ wrote == db_journal_header_size() and synced and closed;
}

@db_journal_is_active(db: DB) -> bool {
    journal := file_open(db_journal_path(db));
    header := file_read(journal, 0, db_journal_header_size());
    closed := file_close(journal);
    ^ db_journal_active(header);
}

@db_restore_journal_pages(db: DB, journal: file, entry_count: i64) -> bool {
    idx := 0;
    ~ (idx < entry_count) {
        entry_offset := db_journal_entry_offset(db.pager.page_size, idx);
        entry_text := file_read(journal, entry_offset, db_journal_entry_size(db.pager.page_size));
        page_id := db_journal_entry_page_id(entry_text);
        page_text := db_journal_entry_page_text(entry_text, db.pager.page_size);
        restored := pager_raw_write_page(db.pager, page_id, page_text);
        ? (restored != db.pager.page_size) {
            ^ false;
        }
        idx = idx + 1;
    }
    ^ true;
}

@db_recover_if_needed(db: DB) -> bool {
    journal := file_open(db_journal_path(db));
    journal_size := file_size(journal);
    ? (journal_size < db_journal_header_size()) {
        closed := file_close(journal);
        ^ true;
    }
    header := file_read(journal, 0, db_journal_header_size());
    ? (not db_journal_active(header)) {
        closed := file_close(journal);
        ^ true;
    }
    entry_count := db_journal_entry_count(header);
    restored := db_restore_journal_pages(db, journal, entry_count);
    synced_db := file_sync(db.pager.handle);
    cleared := file_write(journal, 0, db_journal_header(false, 0, 0));
    synced_journal := file_sync(journal);
    closed := file_close(journal);
    ^ restored and synced_db and cleared == db_journal_header_size() and synced_journal and closed;
}

@db_catalog_page() -> i64 {
    ^ 1;
}

@db_schema_table_name() -> text {
    ^ "__schema";
}

@db_schema_slot_width() -> i64 {
    ^ 96;
}

@db_catalog_count_width() -> i64 {
    ^ 8;
}

@db_catalog_root_width() -> i64 {
    ^ 8;
}

@db_catalog_slot_width_width() -> i64 {
    ^ 8;
}

@db_catalog_name_width() -> i64 {
    ^ 15;
}

@db_catalog_entry_size() -> i64 {
    ^ 1 + db_catalog_root_width() + db_catalog_slot_width_width() + db_catalog_name_width();
}

@db_catalog_capacity(page_size: i64) -> i64 {
    ^ (page_size - 1 - (1 + db_catalog_count_width())) / db_catalog_entry_size();
}

@db_catalog_normalize_name(name: text) -> text {
    trimmed := name;
    ? (count(trimmed) > db_catalog_name_width()) {
        trimmed = slice(trimmed, 0, db_catalog_name_width());
    }
    ^ pad_right(trimmed, db_catalog_name_width(), ".");
}

@db_catalog_page_text(page_size: i64, count0: i64, entries: text) -> text {
    body := "C" + pad_left_i64(count0, db_catalog_count_width()) + entries;
    ^ pad_right(body, page_size - 1, ".");
}

@db_catalog_count(page: text) -> i64 {
    ^ i64_of(slice(page, 2, db_catalog_count_width()));
}

@db_catalog_entries_region(page: text) -> text {
    start := 1 + 1 + db_catalog_count_width();
    ^ slice(page, start, count(page) - start);
}

@db_catalog_entry_text(root_page: i64, slot_width: i64, name: text) -> text {
    ^ "1" + pad_left_i64(root_page, db_catalog_root_width()) + pad_left_i64(slot_width, db_catalog_slot_width_width()) + db_catalog_normalize_name(name);
}

@db_catalog_empty_entry() -> text {
    ^ "0" + repeat_unit(".", db_catalog_entry_size() - 1);
}

@db_catalog_entry_at(entries: text, index: i64) -> text {
    ^ slice(entries, index * db_catalog_entry_size(), db_catalog_entry_size());
}

@db_catalog_entry_is_used(entry: text) -> bool {
    ^ slice(entry, 0, 1) == "1";
}

@db_catalog_entry_root(entry: text) -> i64 {
    ^ i64_of(slice(entry, 1, db_catalog_root_width()));
}

@db_catalog_entry_slot_width(entry: text) -> i64 {
    start := 1 + db_catalog_root_width();
    ^ i64_of(slice(entry, start, db_catalog_slot_width_width()));
}

@db_catalog_entry_name(entry: text) -> text {
    start := 1 + db_catalog_root_width() + db_catalog_slot_width_width();
    ^ slice(entry, start, db_catalog_name_width());
}

@db_catalog_build_entries(capacity: i64, used_entries: text, count0: i64) -> text {
    ^ used_entries + repeat_unit(db_catalog_empty_entry(), capacity - count0);
}

@db_catalog_init(db: DB) -> i64 {
    capacity := db_catalog_capacity(db.pager.page_size);
    entries := repeat_unit(db_catalog_empty_entry(), capacity);
    ^ pager_write_page(db.pager, db_catalog_page(), db_catalog_page_text(db.pager.page_size, 0, entries));
}

@db_open(path: text, page_size: i64) -> DB {
    pager := pager_open(path, page_size);
    db := DB { pager: pager, path: path };
    total_pages := pager_total_pages(pager);
    ? (total_pages == 1) {
        catalog_page := pager_alloc_page(pager);
        initialized := db_catalog_init(db);
    }
    recovered := db_recover_if_needed(db);
    ^ db;
}

@db_catalog_lookup_index(db: DB, name: text) -> i64 {
    page := pager_read_page(db.pager, db_catalog_page());
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    normalized := db_catalog_normalize_name(name);
    index := 0;
    ~ (index < count0) {
        entry := db_catalog_entry_at(entries, index);
        ? (db_catalog_entry_is_used(entry) and db_catalog_entry_name(entry) == normalized) {
            ^ index;
        }
        index = index + 1;
    }
    ^ -1;
}

@db_table_root(db: DB, name: text) -> i64 {
    page := pager_read_page(db.pager, db_catalog_page());
    entries := db_catalog_entries_region(page);
    index := db_catalog_lookup_index(db, name);
    ? (index < 0) {
        ^ -1;
    }
    entry := db_catalog_entry_at(entries, index);
    ^ db_catalog_entry_root(entry);
}

@db_table_slot_width(db: DB, name: text) -> i64 {
    page := pager_read_page(db.pager, db_catalog_page());
    entries := db_catalog_entries_region(page);
    index := db_catalog_lookup_index(db, name);
    ? (index < 0) {
        ^ -1;
    }
    entry := db_catalog_entry_at(entries, index);
    ^ db_catalog_entry_slot_width(entry);
}

@db_create_table(db: DB, name: text, slot_width: i64) -> i64 {
    page := pager_read_page(db.pager, db_catalog_page());
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    capacity := db_catalog_capacity(db.pager.page_size);
    ? (db_catalog_lookup_index(db, name) >= 0) {
        ^ -2;
    }
    ? (count0 >= capacity) {
        ^ -1;
    }
    root_page := pager_alloc_page(db.pager);
    initialized := leaf_init_page(db.pager, root_page, slot_width);
    used_entries := slice(entries, 0, count0 * db_catalog_entry_size());
    updated_used := used_entries + db_catalog_entry_text(root_page, slot_width, name);
    updated_entries := db_catalog_build_entries(capacity, updated_used, count0 + 1);
    wrote := pager_write_page(db.pager, db_catalog_page(), db_catalog_page_text(db.pager.page_size, count0 + 1, updated_entries));
    ? (initialized == db.pager.page_size and wrote == db.pager.page_size) {
        ^ root_page;
    }
    ^ -1;
}

@db_ensure_schema_table(db: DB) -> i64 {
    existing := db_catalog_lookup_index(db, db_schema_table_name());
    ? (existing >= 0) {
        ^ db_table_root(db, db_schema_table_name());
    }
    ^ db_create_table(db, db_schema_table_name(), db_schema_slot_width());
}

@db_schema_payload(name: text, slot_width: i64, fields: text) -> text {
    payload := "";
    payload = row_append(payload, "name", name);
    payload = row_append(payload, "slot_width", text_of(slot_width));
    payload = row_append(payload, "fields", fields);
    ^ payload;
}

@db_define_table(db: DB, name: text, slot_width: i64, fields: text) -> i64 {
    ? (not db_schema_fields_supported(fields)) {
        ^ -5;
    }
    ? (name != db_schema_table_name()) {
        schema_ready := db_ensure_schema_table(db);
        ? (schema_ready < 0) {
            ^ -3;
        }
    }
    root_page := db_create_table(db, name, slot_width);
    ? (root_page < 0) {
        ^ root_page;
    }
    ? (name == db_schema_table_name()) {
        ^ root_page;
    }
    schema_payload := db_schema_payload(name, slot_width, fields);
    schema_written := db_insert(db, db_schema_table_name(), root_page, schema_payload);
    ? (schema_written < 0) {
        ^ -4;
    }
    unique_created := db_create_schema_unique_indexes(db, name, fields);
    ? (unique_created < 0) {
        ^ unique_created;
    }
    ^ root_page;
}

@db_create_index(db: DB, table_name: text, index_name: text) -> i64 {
    index_table := db_index_table_name(table_name, index_name);
    ^ db_create_table(db, index_table, 20);
}

@db_bind_table(db: DB, name: text) -> Table {
    root_page := db_table_root(db, name);
    slot_width := db_table_slot_width(db, name);
    ^ table_bind(db.pager, root_page, slot_width);
}

@db_put(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_put(table, key, payload);
}

@db_insert(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_insert(table, key, payload);
}

@db_update(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_update(table, key, payload);
}

@db_get(db: DB, table_name: text, key: i64) -> text {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ "";
    }
    ^ table_get(table, key);
}

@db_delete(db: DB, table_name: text, key: i64) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_delete(table, key);
}

@db_scan_text(db: DB, table_name: text, separator: text) -> text {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ "";
    }
    ^ table_scan_text(table, separator);
}

@db_scan_key_range_text(db: DB, table_name: text, min_key: i64, max_key: i64, separator: text) -> text {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ "";
    }
    ^ table_scan_key_range_text(table, min_key, max_key, separator);
}

@db_first_key(db: DB, table_name: text) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_first_key_in_order(table);
}

@db_next_key(db: DB, table_name: text, after_key: i64) -> i64 {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ -1;
    }
    ^ table_next_key_in_order(table, after_key);
}

@db_index_put(db: DB, table_name: text, index_name: text, secondary_key: i64, primary_key: i64) -> i64 {
    index_table := db_index_table_name(table_name, index_name);
    ^ db_put(db, index_table, secondary_key, text_of(primary_key));
}

@db_index_insert_unique(db: DB, table_name: text, index_name: text, secondary_key: i64, primary_key: i64) -> i64 {
    existing := db_index_get(db, table_name, index_name, secondary_key);
    ? (existing >= 0 and existing != primary_key) {
        ^ -2;
    }
    index_table := db_index_table_name(table_name, index_name);
    ^ db_insert(db, index_table, secondary_key, text_of(primary_key));
}

@db_index_get(db: DB, table_name: text, index_name: text, secondary_key: i64) -> i64 {
    index_table := db_index_table_name(table_name, index_name);
    value := db_get(db, index_table, secondary_key);
    ? (count(value) == 0) {
        ^ -1;
    }
    ^ i64_of(value);
}

@db_get_by_index(db: DB, table_name: text, index_name: text, secondary_key: i64) -> text {
    primary_key := db_index_get(db, table_name, index_name, secondary_key);
    ? (primary_key < 0) {
        ^ "";
    }
    ^ db_get(db, table_name, primary_key);
}

@db_scan_by_index_key_range_text(db: DB, table_name: text, index_name: text, min_secondary_key: i64, max_secondary_key: i64, separator: text) -> text {
    ? (min_secondary_key > max_secondary_key) {
        ^ "";
    }
    index_table := db_index_table_name(table_name, index_name);
    secondary_key := db_first_key(db, index_table);
    out := "";
    ~ (secondary_key >= 0) {
        ? (secondary_key >= min_secondary_key and secondary_key <= max_secondary_key) {
            row0 := db_get_by_index(db, table_name, index_name, secondary_key);
            normalized := row_trim_padding(row0);
            ? (count(normalized) > 0) {
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + normalized;
            }
        }
        ? (secondary_key > max_secondary_key) {
            ^ out;
        }
        secondary_key = db_next_key(db, index_table, secondary_key);
    }
    ^ out;
}

@db_result_row(key: i64, payload: text) -> text {
    normalized := row_trim_padding(payload);
    ^ row_put(normalized, "__key", text_of(key));
}

@db_scan_key_range_rows_text(db: DB, table_name: text, min_key: i64, max_key: i64, separator: text) -> text {
    ? (min_key > max_key) {
        ^ "";
    }
    key := db_first_key(db, table_name);
    out := "";
    ~ (key >= 0) {
        ? (key >= min_key and key <= max_key) {
            row0 := db_get(db, table_name, key);
            ? (count(row0) > 0) {
                result_row := db_result_row(key, row0);
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + result_row;
            }
        }
        ? (key > max_key) {
            ^ out;
        }
        key = db_next_key(db, table_name, key);
    }
    ^ out;
}

@db_scan_where_field_equals_rows_text(db: DB, table_name: text, field_name: text, expected_value: text, separator: text) -> text {
    key := db_first_key(db, table_name);
    out := "";
    ~ (key >= 0) {
        row0 := db_get(db, table_name, key);
        ? (count(row0) > 0 and row_get(row0, field_name) == expected_value) {
            result_row := db_result_row(key, row0);
            ? (count(out) > 0) {
                out = out + separator;
            }
            out = out + result_row;
        }
        key = db_next_key(db, table_name, key);
    }
    ^ out;
}

@db_scan_by_index_key_range_rows_text(db: DB, table_name: text, index_name: text, min_secondary_key: i64, max_secondary_key: i64, separator: text) -> text {
    ? (min_secondary_key > max_secondary_key) {
        ^ "";
    }
    index_table := db_index_table_name(table_name, index_name);
    secondary_key := db_first_key(db, index_table);
    out := "";
    ~ (secondary_key >= 0) {
        ? (secondary_key >= min_secondary_key and secondary_key <= max_secondary_key) {
            primary_key := db_index_get(db, table_name, index_name, secondary_key);
            row0 := db_get(db, table_name, primary_key);
            ? (count(row0) > 0) {
                result_row := db_result_row(primary_key, row0);
                result_row = row_put(result_row, "__index_key", text_of(secondary_key));
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + result_row;
            }
        }
        ? (secondary_key > max_secondary_key) {
            ^ out;
        }
        secondary_key = db_next_key(db, index_table, secondary_key);
    }
    ^ out;
}

@db_index_delete(db: DB, table_name: text, index_name: text, secondary_key: i64) -> i64 {
    index_table := db_index_table_name(table_name, index_name);
    ^ db_delete(db, index_table, secondary_key);
}

@db_insert_with_index(db: DB, table_name: text, index_name: text, primary_key: i64, payload: text, secondary_key: i64) -> i64 {
    inserted := db_insert(db, table_name, primary_key, payload);
    ? (inserted < 0) {
        ^ inserted;
    }
    indexed := db_index_insert_unique(db, table_name, index_name, secondary_key, primary_key);
    ? (indexed < 0) {
        rollback := db_delete(db, table_name, primary_key);
        ^ indexed;
    }
    ^ 0;
}

@db_update_with_index(db: DB, table_name: text, index_name: text, primary_key: i64, payload: text, old_secondary_key: i64, new_secondary_key: i64) -> i64 {
    old_index_primary := db_index_get(db, table_name, index_name, old_secondary_key);
    ? (old_index_primary != primary_key) {
        ^ -3;
    }
    existing_new := db_index_get(db, table_name, index_name, new_secondary_key);
    ? (existing_new >= 0 and existing_new != primary_key) {
        ^ -2;
    }
    updated := db_update(db, table_name, primary_key, payload);
    ? (updated < 0) {
        ^ updated;
    }
    ? (old_secondary_key != new_secondary_key) {
        deleted := db_index_delete(db, table_name, index_name, old_secondary_key);
        inserted := db_index_insert_unique(db, table_name, index_name, new_secondary_key, primary_key);
        ? (deleted < 0 or inserted < 0) {
            ^ -4;
        }
    }
    ^ 0;
}

@db_delete_with_index(db: DB, table_name: text, index_name: text, primary_key: i64, secondary_key: i64) -> i64 {
    indexed_primary := db_index_get(db, table_name, index_name, secondary_key);
    ? (indexed_primary != primary_key) {
        ^ -3;
    }
    deleted_table := db_delete(db, table_name, primary_key);
    ? (deleted_table < 0) {
        ^ deleted_table;
    }
    deleted_index := db_index_delete(db, table_name, index_name, secondary_key);
    ? (deleted_index < 0) {
        ^ -4;
    }
    ^ 0;
}

@db_row_get(db: DB, table_name: text, key: i64, field_name: text) -> text {
    payload := db_get(db, table_name, key);
    ? (count(payload) == 0) {
        ^ "";
    }
    ^ row_get(payload, field_name);
}

@db_row_put(db: DB, table_name: text, key: i64, field_name: text, field_value: text) -> i64 {
    payload := db_get(db, table_name, key);
    ? (count(payload) == 0) {
        ^ -1;
    }
    updated := row_put(payload, field_name, field_value);
    ^ db_update(db, table_name, key, updated);
}

@db_table_schema(db: DB, table_name: text) -> text {
    ? (table_name == db_schema_table_name()) {
        ^ db_schema_payload(db_schema_table_name(), db_schema_slot_width(), "name:text,slot_width:i64,fields:text");
    }
    schema_index := db_catalog_lookup_index(db, db_schema_table_name());
    ? (schema_index < 0) {
        ^ "";
    }
    root_page := db_table_root(db, table_name);
    ? (root_page < 0) {
        ^ "";
    }
    ^ db_get(db, db_schema_table_name(), root_page);
}

@db_table_fields(db: DB, table_name: text) -> text {
    schema0 := db_table_schema(db, table_name);
    ? (count(schema0) == 0) {
        ^ "";
    }
    ^ row_get(schema0, "fields");
}

@db_catalog_display_name(entry: text) -> text {
    ^ row_trim_padding(db_catalog_entry_name(entry));
}

@db_catalog_text(db: DB, separator: text) -> text {
    page := pager_read_page(db.pager, db_catalog_page());
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    out := "";
    idx := 0;
    ~ (idx < count0) {
        entry := db_catalog_entry_at(entries, idx);
        ? (db_catalog_entry_is_used(entry)) {
            table_name := db_catalog_display_name(entry);
            item := "";
            item = row_append(item, "name", table_name);
            item = row_append(item, "root", text_of(db_catalog_entry_root(entry)));
            item = row_append(item, "slot_width", text_of(db_catalog_entry_slot_width(entry)));
            item = row_append(item, "fields", db_table_fields(db, table_name));
            ? (count(out) > 0) {
                out = out + separator;
            }
            out = out + item;
        }
        idx = idx + 1;
    }
    ^ out;
}

@db_page_map_text(db: DB, separator: text) -> text {
    total_pages := pager_total_pages(db.pager);
    out := "";
    page_id := 0;
    ~ (page_id < total_pages) {
        kind := "";
        ? (page_id == 0) {
            kind = pager_page_kind(pager_load_header(db.pager));
        }
        ? (page_id > 0) {
            page := pager_read_page(db.pager, page_id);
            kind = slice(page, 1, 1);
        }
        item := text_of(page_id) + ":" + kind;
        ? (count(out) > 0) {
            out = out + separator;
        }
        out = out + item;
        page_id = page_id + 1;
    }
    ^ out;
}

@db_schema_field_count(fields_spec: text) -> i64 {
    ? (count(fields_spec) == 0) {
        ^ 0;
    }
    total := 1;
    idx := 0;
    ~ (idx < count(fields_spec)) {
        ? (slice(fields_spec, idx, 1) == ",") {
            total = total + 1;
        }
        idx = idx + 1;
    }
    ^ total;
}

@db_schema_field_at(fields_spec: text, field_index: i64) -> text {
    start := 0;
    idx := 0;
    current := 0;
    ~ (idx < count(fields_spec)) {
        ? (slice(fields_spec, idx, 1) == ",") {
            ? (current == field_index) {
                ^ slice(fields_spec, start, idx - start);
            }
            current = current + 1;
            start = idx + 1;
        }
        idx = idx + 1;
    }
    ? (current == field_index) {
        ^ slice(fields_spec, start, count(fields_spec) - start);
    }
    ^ "";
}

@db_schema_field_name(field_spec: text) -> text {
    colon := find(field_spec, ":");
    ? (colon < 0) {
        ^ "";
    }
    ^ slice(field_spec, 0, colon);
}

@db_schema_field_type(field_spec: text) -> text {
    colon := find(field_spec, ":");
    ? (colon < 0) {
        ^ "";
    }
    tail := slice(field_spec, colon + 1, count(field_spec) - (colon + 1));
    qmark := find(tail, "?");
    bang := find(tail, "!");
    at := find(tail, "@");
    eq := find(tail, "=");
    end0 := count(tail);
    ? (qmark >= 0 and qmark < end0) {
        end0 = qmark;
    }
    ? (bang >= 0 and bang < end0) {
        end0 = bang;
    }
    ? (at >= 0 and at < end0) {
        end0 = at;
    }
    ? (eq >= 0 and eq < end0) {
        end0 = eq;
    }
    ^ slice(tail, 0, end0);
}

@db_schema_field_is_nullable(field_spec: text) -> bool {
    colon := find(field_spec, ":");
    ? (colon < 0) {
        ^ false;
    }
    tail := slice(field_spec, colon + 1, count(field_spec) - (colon + 1));
    qmark := find(tail, "?");
    eq := find(tail, "=");
    ? (qmark < 0) {
        ^ false;
    }
    ? (eq < 0) {
        ^ true;
    }
    ^ qmark < eq;
}

@db_schema_field_default(field_spec: text) -> text {
    eq := find(field_spec, "=");
    ? (eq < 0) {
        ^ "";
    }
    ^ slice(field_spec, eq + 1, count(field_spec) - (eq + 1));
}

@db_schema_field_ref_table(field_spec: text) -> text {
    colon := find(field_spec, ":");
    ? (colon < 0) {
        ^ "";
    }
    tail := slice(field_spec, colon + 1, count(field_spec) - (colon + 1));
    at := find(tail, "@");
    ? (at < 0) {
        ^ "";
    }
    after := slice(tail, at + 1, count(tail) - (at + 1));
    qmark := find(after, "?");
    bang := find(after, "!");
    eq := find(after, "=");
    end0 := count(after);
    ? (qmark >= 0 and qmark < end0) {
        end0 = qmark;
    }
    ? (bang >= 0 and bang < end0) {
        end0 = bang;
    }
    ? (eq >= 0 and eq < end0) {
        end0 = eq;
    }
    ^ slice(after, 0, end0);
}

@db_schema_field_is_unique(field_spec: text) -> bool {
    colon := find(field_spec, ":");
    ? (colon < 0) {
        ^ false;
    }
    tail := slice(field_spec, colon + 1, count(field_spec) - (colon + 1));
    bang := find(tail, "!");
    ? (bang < 0) {
        ^ false;
    }
    eq := find(tail, "=");
    ? (eq < 0) {
        ^ true;
    }
    ^ bang < eq;
}

@db_schema_unique_index_name(field_spec: text) -> text {
    ^ db_schema_field_name(field_spec);
}

@db_schema_fields_supported(fields_spec: text) -> bool {
    count0 := db_schema_field_count(fields_spec);
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        field_name := db_schema_field_name(field_spec);
        type_name := db_schema_field_type(field_spec);
        ? (count(field_name) == 0 or count(type_name) == 0) {
            ^ false;
        }
        ? (db_schema_field_is_unique(field_spec) and type_name != "i64") {
            ^ false;
        }
        ref_table := db_schema_field_ref_table(field_spec);
        ? (count(ref_table) > 0 and type_name != "i64") {
            ^ false;
        }
        idx = idx + 1;
    }
    ^ true;
}

@db_schema_has_field(fields_spec: text, field_name: text) -> bool {
    count0 := db_schema_field_count(fields_spec);
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_name(field_spec) == field_name) {
            ^ true;
        }
        idx = idx + 1;
    }
    ^ false;
}

@db_schema_append_field(fields_spec: text, field_spec: text) -> text {
    ? (count(fields_spec) == 0) {
        ^ field_spec;
    }
    ^ fields_spec + "," + field_spec;
}

@db_create_schema_unique_indexes(db: DB, table_name: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    created := 0;
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_is_unique(field_spec)) {
            built := db_create_index(db, table_name, db_schema_unique_index_name(field_spec));
            ? (built < 0) {
                ^ built;
            }
            created = created + 1;
        }
        idx = idx + 1;
    }
    ^ created;
}

@db_text_is_i64(value: text) -> bool {
    ? (count(value) == 0) {
        ^ false;
    }
    idx := 0;
    ? (slice(value, 0, 1) == "-") {
        ? (count(value) == 1) {
            ^ false;
        }
        idx = 1;
    }
    ~ (idx < count(value)) {
        ch := slice(value, idx, 1);
        ? (find("0123456789", ch) < 0) {
            ^ false;
        }
        idx = idx + 1;
    }
    ^ true;
}

@db_text_is_bool(value: text) -> bool {
    ^ value == "true" or value == "false";
}

@db_value_matches_type(value: text, type_name: text) -> bool {
    ? (type_name == "text") {
        ^ true;
    }
    ? (type_name == "i64") {
        ^ db_text_is_i64(value);
    }
    ? (type_name == "bool") {
        ^ db_text_is_bool(value);
    }
    ^ false;
}

@db_value_matches_field_spec(value: text, field_spec: text) -> bool {
    type_name := db_schema_field_type(field_spec);
    nullable := db_schema_field_is_nullable(field_spec);
    ? (nullable and value == "null") {
        ^ true;
    }
    ^ db_value_matches_type(value, type_name);
}

@db_row_matches_schema(payload: text, fields_spec: text) -> bool {
    expected_count := db_schema_field_count(fields_spec);
    ? (expected_count == 0) {
        ^ true;
    }
    ? (row_field_count(payload) != expected_count) {
        ^ false;
    }
    idx := 0;
    ~ (idx < expected_count) {
        field_spec := db_schema_field_at(fields_spec, idx);
        field_name := db_schema_field_name(field_spec);
        value := row_get(payload, field_name);
        ? (count(field_name) == 0 or count(value) == 0) {
            ^ false;
        }
        ? (not db_value_matches_field_spec(value, field_spec)) {
            ^ false;
        }
        idx = idx + 1;
    }
    ^ true;
}

@db_materialize_insert_row(payload: text, fields_spec: text) -> text {
    expected_count := db_schema_field_count(fields_spec);
    ? (expected_count == 0) {
        ^ payload;
    }
    ? (row_field_count(payload) > expected_count) {
        ^ "";
    }
    out := "";
    idx := 0;
    ~ (idx < expected_count) {
        field_spec := db_schema_field_at(fields_spec, idx);
        field_name := db_schema_field_name(field_spec);
        value := row_get(payload, field_name);
        ? (count(field_name) == 0) {
            ^ "";
        }
        ? (count(value) == 0) {
            default0 := db_schema_field_default(field_spec);
            ? (count(default0) > 0) {
                value = default0;
            }
            ? (count(default0) == 0 and db_schema_field_is_nullable(field_spec)) {
                value = "null";
            }
        }
        ? (count(value) == 0 or not db_value_matches_field_spec(value, field_spec)) {
            ^ "";
        }
        out = row_append(out, field_name, value);
        idx = idx + 1;
    }
    ^ out;
}

@db_backfill_add_field_payload(payload: text, field_spec: text) -> text {
    field_name := db_schema_field_name(field_spec);
    value := row_get(payload, field_name);
    ? (count(value) > 0) {
        ^ payload;
    }
    default0 := db_schema_field_default(field_spec);
    ? (count(default0) > 0) {
        ^ row_put(payload, field_name, default0);
    }
    ? (db_schema_field_is_nullable(field_spec)) {
        ^ row_put(payload, field_name, "null");
    }
    ^ "";
}

@db_create_indexes_for_new_field(db: DB, table_name: text, field_spec: text) -> i64 {
    ? (db_schema_field_is_unique(field_spec)) {
        ^ db_create_index(db, table_name, db_schema_unique_index_name(field_spec));
    }
    ^ 0;
}

@db_rebuild_indexes_for_new_field(db: DB, table_name: text, field_spec: text) -> i64 {
    ? (db_schema_field_is_unique(field_spec)) {
        ^ db_rebuild_index_from_field(db, table_name, db_schema_unique_index_name(field_spec), db_schema_field_name(field_spec));
    }
    ^ 0;
}

@db_unique_fields_precheck(db: DB, table_name: text, primary_key: i64, payload: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_is_unique(field_spec)) {
            field_name := db_schema_field_name(field_spec);
            value_text := row_get(payload, field_name);
            ? (value_text != "null") {
                ? (not db_text_is_i64(value_text)) {
                    ^ -3;
                }
                existing := db_index_get(db, table_name, db_schema_unique_index_name(field_spec), i64_of(value_text));
                ? (existing >= 0 and existing != primary_key) {
                    ^ -4;
                }
            }
        }
        idx = idx + 1;
    }
    ^ 0;
}

@db_foreign_keys_precheck(db: DB, payload: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ref_table := db_schema_field_ref_table(field_spec);
        ? (count(ref_table) > 0) {
            field_name := db_schema_field_name(field_spec);
            value_text := row_get(payload, field_name);
            ? (value_text != "null") {
                ? (not db_text_is_i64(value_text)) {
                    ^ -6;
                }
                referenced := db_get(db, ref_table, i64_of(value_text));
                ? (count(referenced) == 0) {
                    ^ -7;
                }
            }
        }
        idx = idx + 1;
    }
    ^ 0;
}

@db_unique_fields_insert_indexes(db: DB, table_name: text, primary_key: i64, payload: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    inserted := 0;
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_is_unique(field_spec)) {
            field_name := db_schema_field_name(field_spec);
            value_text := row_get(payload, field_name);
            ? (value_text != "null") {
                wrote := db_index_insert_unique(db, table_name, db_schema_unique_index_name(field_spec), i64_of(value_text), primary_key);
                ? (wrote < 0) {
                    ^ wrote;
                }
                inserted = inserted + 1;
            }
        }
        idx = idx + 1;
    }
    ^ inserted;
}

@db_unique_fields_update_indexes(db: DB, table_name: text, primary_key: i64, old_payload: text, new_payload: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_is_unique(field_spec)) {
            field_name := db_schema_field_name(field_spec);
            old_value := row_get(old_payload, field_name);
            new_value := row_get(new_payload, field_name);
            ? (old_value != new_value) {
                deleted := 0;
                ? (db_text_is_i64(old_value)) {
                    deleted = db_index_delete(db, table_name, db_schema_unique_index_name(field_spec), i64_of(old_value));
                }
                inserted := 0;
                ? (db_text_is_i64(new_value)) {
                    inserted = db_index_insert_unique(db, table_name, db_schema_unique_index_name(field_spec), i64_of(new_value), primary_key);
                }
                ? (deleted < 0 or inserted < 0) {
                    ^ -5;
                }
            }
        }
        idx = idx + 1;
    }
    ^ 0;
}

@db_unique_fields_delete_indexes(db: DB, table_name: text, payload: text, fields_spec: text) -> i64 {
    count0 := db_schema_field_count(fields_spec);
    deleted := 0;
    idx := 0;
    ~ (idx < count0) {
        field_spec := db_schema_field_at(fields_spec, idx);
        ? (db_schema_field_is_unique(field_spec)) {
            field_name := db_schema_field_name(field_spec);
            value_text := row_get(payload, field_name);
            ? (db_text_is_i64(value_text)) {
                removed := db_index_delete(db, table_name, db_schema_unique_index_name(field_spec), i64_of(value_text));
                ? (removed >= 0) {
                    deleted = deleted + 1;
                }
            }
        }
        idx = idx + 1;
    }
    ^ deleted;
}

@db_insert_row(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    fields_spec := db_table_fields(db, table_name);
    materialized := payload;
    ? (count(fields_spec) > 0) {
        materialized = db_materialize_insert_row(payload, fields_spec);
        ? (count(materialized) == 0) {
            ^ -2;
        }
        unique_ok := db_unique_fields_precheck(db, table_name, key, materialized, fields_spec);
        ? (unique_ok < 0) {
            ^ unique_ok;
        }
        refs_ok := db_foreign_keys_precheck(db, materialized, fields_spec);
        ? (refs_ok < 0) {
            ^ refs_ok;
        }
    }
    inserted := db_insert(db, table_name, key, materialized);
    ? (inserted < 0) {
        ^ inserted;
    }
    ? (count(fields_spec) > 0) {
        indexed := db_unique_fields_insert_indexes(db, table_name, key, materialized, fields_spec);
        ? (indexed < 0) {
            rollback := db_delete(db, table_name, key);
            ^ indexed;
        }
    }
    ^ inserted;
}

@db_update_row(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    fields_spec := db_table_fields(db, table_name);
    ? (count(fields_spec) > 0 and not db_row_matches_schema(payload, fields_spec)) {
        ^ -2;
    }
    old_payload := db_get(db, table_name, key);
    ? (count(old_payload) == 0) {
        ^ -1;
    }
    ? (count(fields_spec) > 0) {
        unique_ok := db_unique_fields_precheck(db, table_name, key, payload, fields_spec);
        ? (unique_ok < 0) {
            ^ unique_ok;
        }
        refs_ok := db_foreign_keys_precheck(db, payload, fields_spec);
        ? (refs_ok < 0) {
            ^ refs_ok;
        }
    }
    updated := db_update(db, table_name, key, payload);
    ? (updated < 0) {
        ^ updated;
    }
    ? (count(fields_spec) > 0) {
        synced := db_unique_fields_update_indexes(db, table_name, key, old_payload, payload, fields_spec);
        ? (synced < 0) {
            ^ synced;
        }
    }
    ^ updated;
}

@db_put_row(db: DB, table_name: text, key: i64, payload: text) -> i64 {
    fields_spec := db_table_fields(db, table_name);
    materialized := payload;
    old_payload := db_get(db, table_name, key);
    ? (count(fields_spec) > 0) {
        ? (count(old_payload) == 0) {
            materialized = db_materialize_insert_row(payload, fields_spec);
            ? (count(materialized) == 0) {
                ^ -2;
            }
        }
        ? (count(old_payload) > 0 and not db_row_matches_schema(payload, fields_spec)) {
            ^ -2;
        }
        ? (count(old_payload) > 0) {
            materialized = payload;
        }
        unique_ok := db_unique_fields_precheck(db, table_name, key, materialized, fields_spec);
        ? (unique_ok < 0) {
            ^ unique_ok;
        }
        refs_ok := db_foreign_keys_precheck(db, materialized, fields_spec);
        ? (refs_ok < 0) {
            ^ refs_ok;
        }
    }
    wrote := db_put(db, table_name, key, materialized);
    ? (wrote < 0) {
        ^ wrote;
    }
    ? (count(fields_spec) > 0 and count(old_payload) == 0) {
        indexed := db_unique_fields_insert_indexes(db, table_name, key, materialized, fields_spec);
        ? (indexed < 0) {
            rollback := db_delete(db, table_name, key);
            ^ indexed;
        }
    }
    ? (count(fields_spec) > 0 and count(old_payload) > 0) {
        synced := db_unique_fields_update_indexes(db, table_name, key, old_payload, materialized, fields_spec);
        ? (synced < 0) {
            ^ synced;
        }
    }
    ^ wrote;
}

@db_has_reference_to_key(db: DB, target_table_name: text, key: i64) -> bool {
    page := pager_read_page(db.pager, db_catalog_page());
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    key_text := text_of(key);
    idx := 0;
    ~ (idx < count0) {
        entry := db_catalog_entry_at(entries, idx);
        ? (db_catalog_entry_is_used(entry)) {
            table_name := db_catalog_display_name(entry);
            fields_spec := db_table_fields(db, table_name);
            field_count := db_schema_field_count(fields_spec);
            field_index := 0;
            ~ (field_index < field_count) {
                field_spec := db_schema_field_at(fields_spec, field_index);
                ? (db_schema_field_ref_table(field_spec) == target_table_name) {
                    field_name := db_schema_field_name(field_spec);
                    matches := db_scan_where_field_equals(db, table_name, field_name, key_text, "|");
                    ? (count(matches) > 0) {
                        ^ true;
                    }
                }
                field_index = field_index + 1;
            }
        }
        idx = idx + 1;
    }
    ^ false;
}

@db_delete_row(db: DB, table_name: text, key: i64) -> i64 {
    fields_spec := db_table_fields(db, table_name);
    payload := db_get(db, table_name, key);
    ? (count(payload) == 0) {
        ^ -1;
    }
    ? (db_has_reference_to_key(db, table_name, key)) {
        ^ -8;
    }
    deleted := db_delete(db, table_name, key);
    ? (deleted < 0) {
        ^ deleted;
    }
    ? (count(fields_spec) > 0) {
        cleaned := db_unique_fields_delete_indexes(db, table_name, payload, fields_spec);
    }
    ^ deleted;
}

@db_alter_table_add_field(db: DB, table_name: text, field_spec: text) -> i64 {
    schema_payload := db_table_schema(db, table_name);
    ? (count(schema_payload) == 0) {
        ^ -1;
    }
    field_name := db_schema_field_name(field_spec);
    ? (count(field_name) == 0 or not db_schema_fields_supported(field_spec)) {
        ^ -2;
    }
    old_fields := row_get(schema_payload, "fields");
    ? (db_schema_has_field(old_fields, field_name)) {
        ^ -3;
    }
    backfill_probe := db_backfill_add_field_payload("", field_spec);
    ? (count(backfill_probe) == 0) {
        ^ -4;
    }
    new_fields := db_schema_append_field(old_fields, field_spec);
    updated_schema := row_put(schema_payload, "fields", new_fields);
    schema_key := db_table_root(db, table_name);
    schema_updated := db_update(db, db_schema_table_name(), schema_key, updated_schema);
    ? (schema_updated < 0) {
        ^ -5;
    }
    index_created := db_create_indexes_for_new_field(db, table_name, field_spec);
    ? (index_created < 0 and index_created != -2) {
        ^ -6;
    }
    key := db_first_key(db, table_name);
    updated_count := 0;
    ~ (key >= 0) {
        payload := db_get(db, table_name, key);
        updated_payload := db_backfill_add_field_payload(payload, field_spec);
        ? (count(updated_payload) == 0) {
            ^ -7;
        }
        wrote := db_update_row(db, table_name, key, updated_payload);
        ? (wrote < 0) {
            ^ wrote;
        }
        updated_count = updated_count + 1;
        key = db_next_key(db, table_name, key);
    }
    rebuilt := db_rebuild_indexes_for_new_field(db, table_name, field_spec);
    ? (rebuilt < 0) {
        ^ rebuilt;
    }
    ^ updated_count;
}

@db_scan_keys_text(db: DB, table_name: text, separator: text) -> text {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ "";
    }
    ^ table_scan_keys_text(table, separator);
}

@db_delete_keys_text(db: DB, table_name: text, keys_text: text, separator: text) -> i64 {
    remaining := keys_text;
    deleted := 0;
    ~ (count(remaining) > 0) {
        split_at := find(remaining, separator);
        item := remaining;
        next_remaining := "";
        ? (split_at >= 0) {
            item = slice(remaining, 0, split_at);
            next_remaining = slice(remaining, split_at + count(separator), count(remaining) - (split_at + count(separator)));
        }
        ? (count(item) > 0) {
            key := i64_of(item);
            removed := db_delete(db, table_name, key);
            ? (removed >= 0) {
                deleted = deleted + 1;
            }
        }
        remaining = next_remaining;
    }
    ^ deleted;
}

@db_rebuild_index_from_field_page(db: DB, table: Table, table_name: text, index_name: text, field_name: text, page_id: i64) -> i64 {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        page := leaf_read_page(table.pager, page_id);
        slot_count := leaf_slot_count(page);
        slot_width := leaf_slot_width(page);
        entries := leaf_entries_region(page);
        built := 0;
        slot_index := 0;
        ~ (slot_index < slot_count) {
            slot := leaf_slot_text_at(entries, slot_width, slot_index);
            primary_key := leaf_slot_key(slot);
            payload := leaf_slot_payload(slot);
            secondary_text := row_get(payload, field_name);
            ? (count(secondary_text) == 0) {
                ^ -3;
            }
            ? (secondary_text != "null") {
                ? (not db_text_is_i64(secondary_text)) {
                    ^ -3;
                }
                inserted := db_index_insert_unique(db, table_name, index_name, i64_of(secondary_text), primary_key);
                ? (inserted < 0) {
                    ^ inserted;
                }
                built = built + 1;
            }
            slot_index = slot_index + 1;
        }
        ^ built;
    }
    ? (page_kind == "I") {
        page := pager_read_page(table.pager, page_id);
        key_count := table_internal_key_count(page);
        used_cells := table_internal_used_cells(page);
        total := db_rebuild_index_from_field_page(db, table, table_name, index_name, field_name, table_internal_left_child(page));
        ? (total < 0) {
            ^ total;
        }
        cell_index := 0;
        ~ (cell_index < key_count) {
            cell := table_internal_cell_at(used_cells, cell_index);
            built := db_rebuild_index_from_field_page(db, table, table_name, index_name, field_name, table_internal_cell_child(cell));
            ? (built < 0) {
                ^ built;
            }
            total = total + built;
            cell_index = cell_index + 1;
        }
        ^ total;
    }
    ^ -5;
}

@db_rebuild_index_from_field(db: DB, table_name: text, index_name: text, field_name: text) -> i64 {
    base_table := db_bind_table(db, table_name);
    index_table_name := db_index_table_name(table_name, index_name);
    index_table := db_bind_table(db, index_table_name);
    ? (base_table.root_page < 0 or index_table.root_page < 0) {
        ^ -1;
    }
    existing_keys := db_scan_keys_text(db, index_table_name, ",");
    cleared := db_delete_keys_text(db, index_table_name, existing_keys, ",");
    rebuilt := db_rebuild_index_from_field_page(db, base_table, table_name, index_name, field_name, base_table.root_page);
    ^ rebuilt;
}

@db_repair_unique_indexes(db: DB) -> i64 {
    page := pager_read_page(db.pager, db_catalog_page());
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    repaired := 0;
    idx := 0;
    ~ (idx < count0) {
        entry := db_catalog_entry_at(entries, idx);
        ? (db_catalog_entry_is_used(entry)) {
            table_name := db_catalog_display_name(entry);
            ? (slice(table_name, 0, 4) != "idx.") {
                fields_spec := db_table_fields(db, table_name);
                field_count := db_schema_field_count(fields_spec);
                field_index := 0;
                ~ (field_index < field_count) {
                    field_spec := db_schema_field_at(fields_spec, field_index);
                    ? (db_schema_field_is_unique(field_spec)) {
                        rebuilt := db_rebuild_index_from_field(db, table_name, db_schema_unique_index_name(field_spec), db_schema_field_name(field_spec));
                        ? (rebuilt < 0) {
                            ^ rebuilt;
                        }
                        repaired = repaired + 1;
                    }
                    field_index = field_index + 1;
                }
            }
        }
        idx = idx + 1;
    }
    ^ repaired;
}

@db_scan_where_page(db: DB, table: Table, page_id: i64, field_name: text, expected_value: text, separator: text) -> text {
    page_kind := table_page_kind(table, page_id);
    ? (page_kind == "L") {
        page := leaf_read_page(table.pager, page_id);
        slot_count := leaf_slot_count(page);
        out := "";
        slot_index := 0;
        ~ (slot_index < slot_count) {
            value := leaf_read_slot(table.pager, page_id, slot_index);
            ? (count(value) > 0 and row_get(value, field_name) == expected_value) {
                normalized := row_trim_padding(value);
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + normalized;
            }
            slot_index = slot_index + 1;
        }
        ^ out;
    }
    ? (page_kind == "I") {
        page := pager_read_page(table.pager, page_id);
        key_count := table_internal_key_count(page);
        used_cells := table_internal_used_cells(page);
        out := db_scan_where_page(db, table, table_internal_left_child(page), field_name, expected_value, separator);
        cell_index := 0;
        ~ (cell_index < key_count) {
            cell := table_internal_cell_at(used_cells, cell_index);
            child_text := db_scan_where_page(db, table, table_internal_cell_child(cell), field_name, expected_value, separator);
            ? (count(child_text) > 0) {
                ? (count(out) > 0) {
                    out = out + separator;
                }
                out = out + child_text;
            }
            cell_index = cell_index + 1;
        }
        ^ out;
    }
    ^ "";
}

@db_scan_where_field_equals(db: DB, table_name: text, field_name: text, expected_value: text, separator: text) -> text {
    table := db_bind_table(db, table_name);
    ? (table.root_page < 0 or table.slot_width < 0) {
        ^ "";
    }
    ^ db_scan_where_page(db, table, table.root_page, field_name, expected_value, separator);
}

@db_validate(db: DB) -> bool {
    page := pager_read_page(db.pager, db_catalog_page());
    ? (slice(page, 1, 1) != "C") {
        ^ false;
    }
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    total_pages := pager_total_pages(db.pager);
    idx := 0;
    ~ (idx < count0) {
        entry := db_catalog_entry_at(entries, idx);
        ? (not db_catalog_entry_is_used(entry)) {
            ^ false;
        }
        root_page := db_catalog_entry_root(entry);
        slot_width := db_catalog_entry_slot_width(entry);
        ? (root_page <= 0 or root_page >= total_pages or slot_width <= 0) {
            ^ false;
        }
        table := table_bind(db.pager, root_page, slot_width);
        ? (not table_validate(table)) {
            ^ false;
        }
        idx = idx + 1;
    }
    ^ true;
}

@db_validate_report(db: DB) -> text {
    page := pager_read_page(db.pager, db_catalog_page());
    ? (slice(page, 1, 1) != "C") {
        ^ "catalog page marker is invalid";
    }
    count0 := db_catalog_count(page);
    entries := db_catalog_entries_region(page);
    total_pages := pager_total_pages(db.pager);
    idx := 0;
    ~ (idx < count0) {
        entry := db_catalog_entry_at(entries, idx);
        ? (not db_catalog_entry_is_used(entry)) {
            ^ "catalog entry " + text_of(idx) + " is not marked used";
        }
        root_page := db_catalog_entry_root(entry);
        slot_width := db_catalog_entry_slot_width(entry);
        table_name := db_catalog_entry_name(entry);
        ? (root_page <= 0 or root_page >= total_pages) {
            ^ "catalog table " + table_name + " has invalid root page";
        }
        ? (slot_width <= 0) {
            ^ "catalog table " + table_name + " has invalid slot width";
        }
        table := table_bind(db.pager, root_page, slot_width);
        report := table_validate_report(table);
        ? (report != "ok") {
            ^ "table " + table_name + " invalid: " + report;
        }
        idx = idx + 1;
    }
    ^ "ok";
}

@db_sync(db: DB) -> bool {
    ^ pager_sync(db.pager);
}

@db_begin(db: DB) -> bool {
    journal := file_open(db_journal_path(db));
    header := file_read(journal, 0, db_journal_header_size());
    ? (db_journal_active(header)) {
        closed := file_close(journal);
        ^ false;
    }
    total_pages := pager_total_pages(db.pager);
    wrote_header := file_write(journal, 0, db_journal_header(true, total_pages, total_pages));
    wrote_pages := 0;
    page_id := 0;
    ~ (page_id < total_pages) {
        page_text := pager_raw_read_page(db.pager, page_id);
        entry_offset := db_journal_entry_offset(db.pager.page_size, page_id);
        wrote_entry := file_write(journal, entry_offset, db_journal_entry_text(page_id, page_text));
        ? (wrote_entry != db_journal_entry_size(db.pager.page_size)) {
            closed := file_close(journal);
            ^ false;
        }
        wrote_pages = wrote_pages + 1;
        page_id = page_id + 1;
    }
    synced := file_sync(journal);
    closed := file_close(journal);
    ^ wrote_header == db_journal_header_size() and wrote_pages == total_pages and synced and closed;
}

@db_commit(db: DB) -> bool {
    ^ db_journal_clear(db);
}

@db_rollback(db: DB) -> bool {
    journal := file_open(db_journal_path(db));
    journal_size := file_size(journal);
    ? (journal_size < db_journal_header_size()) {
        closed := file_close(journal);
        ^ false;
    }
    header := file_read(journal, 0, db_journal_header_size());
    ? (not db_journal_active(header)) {
        closed := file_close(journal);
        ^ false;
    }
    entry_count := db_journal_entry_count(header);
    restored := db_restore_journal_pages(db, journal, entry_count);
    synced_db := file_sync(db.pager.handle);
    cleared := file_write(journal, 0, db_journal_header(false, 0, 0));
    synced_journal := file_sync(journal);
    closed := file_close(journal);
    ^ restored and synced_db and cleared == db_journal_header_size() and synced_journal and closed;
}

@db_close(db: DB) -> bool {
    ^ pager_close(db.pager);
}

@db_backup(db: DB, backup_path: text) -> bool {
    ? (db_journal_is_active(db)) {
        ^ false;
    }
    synced := db_sync(db);
    ? (not synced) {
        ^ false;
    }
    size0 := pager_file_size(db.pager);
    snapshot := file_read_bytes(db.pager.handle, 0, size0);
    backup := file_open(backup_path);
    wrote := file_write(backup, 0, snapshot);
    synced_backup := file_sync(backup);
    closed := file_close(backup);
    ^ wrote == size0 and synced_backup and closed;
}

@db_restore_copy(backup_path: text, restore_path: text) -> bool {
    backup := file_open(backup_path);
    size0 := file_size(backup);
    snapshot := file_read_bytes(backup, 0, size0);
    closed_backup := file_close(backup);
    ? (not closed_backup) {
        ^ false;
    }
    restored := file_open(restore_path);
    wrote := file_write(restored, 0, snapshot);
    synced_restored := file_sync(restored);
    closed_restored := file_close(restored);
    ^ wrote == size0 and synced_restored and closed_restored;
}
