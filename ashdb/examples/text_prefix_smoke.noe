& "../lib/db.noe";

@user_row(name: text, role: text) -> text {
    payload := "";
    payload = row_append(payload, "name", name);
    payload = row_append(payload, "role", role);
    ^ payload;
}

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: text_prefix_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 256);
    defined := db_define_table(db, "users", 96, "name:text,role:text");
    ins0 := db_insert_row(db, "users", 10, user_row("alice", "cook"));
    ins1 := db_insert_row(db, "users", 20, user_row("allen", "shop"));
    ins2 := db_insert_row(db, "users", 30, user_row("bob", "cook"));
    ins3 := db_insert_row(db, "users", 40, user_row("ally", "plan"));

    match0 := db_scan_where_field_text_prefix_text(db, "users", "name", "al", "|");
    match1 := db_scan_where_field_text_prefix_rows_text(db, "users", "name", "all", "|");
    match2 := db_scan_where_field_text_prefix_text(db, "users", "role", "co", "|");
    match3 := db_scan_where_field_text_prefix_text(db, "users", "name", "z", "|");
    match4 := db_scan_where_field_text_prefix_text(db, "users", "name", "", "|");
    closed0 := db_close(db);

    reopened := db_open(arg(1), 256);
    match5 := db_scan_where_field_text_prefix_rows_text(reopened, "users", "name", "al", "|");
    validate0 := db_validate_report(reopened);
    closed1 := db_close(reopened);

    ? (defined <= 0 or ins0 < 0 or ins1 < 0 or ins2 < 0 or ins3 < 0) {
        ! "setup=" + text_of(defined) + ":" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(ins2) + ":" + text_of(ins3);
        ^ 2;
    }
    ? (find(match0, "name=alice;") < 0 or find(match0, "name=allen;") < 0 or find(match0, "name=ally;") < 0 or find(match0, "name=bob;") >= 0) {
        ! "match0=" + match0;
        ^ 3;
    }
    ? (find(match1, "__key=20;") < 0 or find(match1, "__key=40;") < 0 or find(match1, "__key=10;") >= 0) {
        ! "match1=" + match1;
        ^ 4;
    }
    ? (find(match2, "name=alice;") < 0 or find(match2, "name=bob;") < 0 or find(match2, "name=allen;") >= 0) {
        ! "match2=" + match2;
        ^ 5;
    }
    ? (count(match3) != 0 or find(match4, "name=bob;") < 0) {
        ! "match3=" + match3 + ":" + match4;
        ^ 6;
    }
    ? (find(match5, "__key=10;") < 0 or find(match5, "__key=20;") < 0 or find(match5, "__key=40;") < 0 or validate0 != "ok" or not closed0 or not closed1) {
        ! "match5=" + match5 + ":" + validate0;
        ^ 7;
    }

    ! "ashdb text prefix smoke ok";
    ^ 0;
}
