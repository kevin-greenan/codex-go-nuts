& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: rowset_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_define_table(db, "users", 96, "name:text,email_key:i64!,role:text");

    row10 := "";
    row10 = row_append(row10, "name", "alice");
    row10 = row_append(row10, "email_key", "1001");
    row10 = row_append(row10, "role", "cook");

    row20 := "";
    row20 = row_append(row20, "name", "bob");
    row20 = row_append(row20, "email_key", "1002");
    row20 = row_append(row20, "role", "shop");

    row30 := "";
    row30 = row_append(row30, "name", "cara");
    row30 = row_append(row30, "email_key", "1003");
    row30 = row_append(row30, "role", "cook");

    ins0 := db_insert_row(db, "users", 10, row10);
    ins1 := db_insert_row(db, "users", 20, row20);
    ins2 := db_insert_row(db, "users", 30, row30);

    range_rows0 := db_scan_key_range_rows_text(db, "users", 15, 30, "|");
    where_rows0 := db_scan_where_field_equals_rows_text(db, "users", "role", "cook", "|");
    index_rows0 := db_scan_by_index_key_range_rows_text(db, "users", "email_key", 1002, 1003, "|");
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    users_root1 := db_table_root(reopened, "users");
    range_rows1 := db_scan_key_range_rows_text(reopened, "users", 10, 20, "|");
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root < 0 or users_root1 != users_root) {
        ! "root=" + text_of(users_root) + ":" + text_of(users_root1);
        ^ 2;
    }
    ? (ins0 < 0 or ins1 < 0 or ins2 < 0) {
        ! "ins=" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(ins2);
        ^ 3;
    }
    ? (find(range_rows0, "__key=20;") < 0 or find(range_rows0, "name=bob;") < 0 or find(range_rows0, "__key=30;") < 0) {
        ! "range0=" + range_rows0;
        ^ 4;
    }
    ? (find(where_rows0, "__key=10;") < 0 or find(where_rows0, "__key=30;") < 0 or find(where_rows0, "role=cook;") < 0) {
        ! "where0=" + where_rows0;
        ^ 5;
    }
    ? (find(index_rows0, "__index_key=1002;") < 0 or find(index_rows0, "__key=20;") < 0 or find(index_rows0, "__index_key=1003;") < 0) {
        ! "index0=" + index_rows0;
        ^ 6;
    }
    ? (find(range_rows1, "__key=10;") < 0 or find(range_rows1, "__key=20;") < 0) {
        ! "range1=" + range_rows1;
        ^ 7;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 8;
    }

    ! "ashdb rowset smoke ok";
    ^ 0;
}
