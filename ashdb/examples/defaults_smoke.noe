& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: defaults_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_define_table(db, "users", 96, "name:text,role:text=member,note:text?,active:bool=true");

    row0 := "";
    row0 = row_append(row0, "name", "alice");

    row1 := "";
    row1 = row_append(row1, "name", "bob");
    row1 = row_append(row1, "role", "admin");
    row1 = row_append(row1, "note", "hello");
    row1 = row_append(row1, "active", "false");

    row_bad := "";
    row_bad = row_append(row_bad, "name", "cara");
    row_bad = row_append(row_bad, "active", "maybe");

    ins0 := db_insert_row(db, "users", 10, row0);
    ins1 := db_insert_row(db, "users", 20, row1);
    bad0 := db_insert_row(db, "users", 30, row_bad);

    role0 := db_row_get(db, "users", 10, "role");
    note0 := db_row_get(db, "users", 10, "note");
    active0 := db_row_get(db, "users", 10, "active");
    role1 := db_row_get(db, "users", 20, "role");
    note1 := db_row_get(db, "users", 20, "note");
    active1 := db_row_get(db, "users", 20, "active");

    update_partial := "";
    update_partial = row_append(update_partial, "name", "alice");
    bad_update := db_update_row(db, "users", 10, update_partial);
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    role2 := db_row_get(reopened, "users", 10, "role");
    note2 := db_row_get(reopened, "users", 10, "note");
    active2 := db_row_get(reopened, "users", 10, "active");
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root < 0) {
        ! "root=" + text_of(users_root);
        ^ 2;
    }
    ? (ins0 < 0 or ins1 < 0 or bad0 != -2) {
        ! "ins=" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(bad0);
        ^ 3;
    }
    ? (role0 != "member" or note0 != "null" or active0 != "true") {
        ! "row0=" + role0 + ":" + note0 + ":" + active0;
        ^ 4;
    }
    ? (role1 != "admin" or note1 != "hello" or active1 != "false") {
        ! "row1=" + role1 + ":" + note1 + ":" + active1;
        ^ 5;
    }
    ? (bad_update != -2) {
        ! "update=" + text_of(bad_update);
        ^ 6;
    }
    ? (role2 != "member" or note2 != "null" or active2 != "true") {
        ! "row2=" + role2 + ":" + note2 + ":" + active2;
        ^ 7;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 8;
    }

    ! "ashdb defaults smoke ok";
    ^ 0;
}
