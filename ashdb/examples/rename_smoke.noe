& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: rename_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 256);
    defined := db_define_table(db, "users", 96, "name:text,role:text,active:bool=false");

    row0 := "";
    row0 = row_append(row0, "name", "alice");
    row0 = row_append(row0, "role", "cook");
    row0 = row_append(row0, "active", "true");

    row1 := "";
    row1 = row_append(row1, "name", "bob");
    row1 = row_append(row1, "role", "shop");
    row1 = row_append(row1, "active", "false");

    ins0 := db_insert_row(db, "users", 10, row0);
    ins1 := db_insert_row(db, "users", 20, row1);

    renamed := db_alter_table_rename_field(db, "users", "role", "duty");
    schema0 := db_table_fields(db, "users");
    stored0 := db_get(db, "users", 10);
    stored1 := db_get(db, "users", 20);

    bad0 := db_alter_table_rename_field(db, "users", "missing", "x");
    bad1 := db_alter_table_rename_field(db, "users", "duty", "name");
    validate0 := db_validate_report(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 256);
    schema1 := db_table_fields(reopened, "users");
    stored2 := db_get(reopened, "users", 10);
    stored3 := db_get(reopened, "users", 20);
    range0 := db_scan_where_field_equals(reopened, "users", "duty", "cook", "|");
    validate1 := db_validate_report(reopened);
    closed1 := db_close(reopened);

    ? (defined <= 0 or ins0 < 0 or ins1 < 0) {
        ! "setup=" + text_of(defined) + ":" + text_of(ins0) + ":" + text_of(ins1);
        ^ 2;
    }
    ? (renamed != 2 or schema0 != "name:text,duty:text,active:bool=false") {
        ! "schema0=" + text_of(renamed) + ":" + schema0;
        ^ 3;
    }
    ? (row_get(stored0, "role") != "" or row_get(stored0, "duty") != "cook" or row_get(stored1, "duty") != "shop") {
        ! "stored=" + stored0 + ":" + stored1;
        ^ 4;
    }
    ? (bad0 != -3 or bad1 != -4 or validate0 != "ok") {
        ! "bad=" + text_of(bad0) + ":" + text_of(bad1) + ":" + validate0;
        ^ 5;
    }
    ? (schema1 != schema0 or row_get(stored2, "duty") != "cook" or row_get(stored3, "duty") != "shop" or range0 != "name=alice;duty=cook;active=true;" or validate1 != "ok" or not closed0 or not closed1) {
        ! "reopen=" + schema1 + ":" + stored2 + ":" + stored3 + ":" + range0 + ":" + validate1;
        ^ 6;
    }

    ! "ashdb rename smoke ok";
    ^ 0;
}
