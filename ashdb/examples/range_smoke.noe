& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: range_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_define_table(db, "users", 96, "name:text,email:text,role:text");

    row10 := "";
    row10 = row_append(row10, "name", "alice");
    row10 = row_append(row10, "email", "alice@home");
    row10 = row_append(row10, "role", "cook");

    row20 := "";
    row20 = row_append(row20, "name", "bob");
    row20 = row_append(row20, "email", "bob@home");
    row20 = row_append(row20, "role", "shop");

    row30 := "";
    row30 = row_append(row30, "name", "cara");
    row30 = row_append(row30, "email", "cara@home");
    row30 = row_append(row30, "role", "cook");

    row40 := "";
    row40 = row_append(row40, "name", "drew");
    row40 = row_append(row40, "email", "drew@home");
    row40 = row_append(row40, "role", "clean");

    ins0 := db_insert_row(db, "users", 10, row10);
    ins1 := db_insert_row(db, "users", 20, row20);
    ins2 := db_insert_row(db, "users", 30, row30);
    ins3 := db_insert_row(db, "users", 40, row40);

    range0 := db_scan_key_range_text(db, "users", 15, 35, "|");
    range1 := db_scan_key_range_text(db, "users", 30, 30, "|");
    range2 := db_scan_key_range_text(db, "users", 50, 60, "|");
    range3 := db_scan_key_range_text(db, "users", 40, 10, "|");
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    users_root1 := db_table_root(reopened, "users");
    range4 := db_scan_key_range_text(reopened, "users", 1, 25, "|");
    range5 := db_scan_key_range_text(reopened, "users", 1, 100, "|");
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root < 0 or users_root1 != users_root) {
        ! "root=" + text_of(users_root) + ":" + text_of(users_root1);
        ^ 2;
    }
    ? (ins0 < 0 or ins1 < 0 or ins2 < 0 or ins3 < 0) {
        ! "ins=" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(ins2) + ":" + text_of(ins3);
        ^ 3;
    }
    ? (range0 != "name=bob;email=bob@home;role=shop;|name=cara;email=cara@home;role=cook;") {
        ! "range0=" + range0;
        ^ 4;
    }
    ? (range1 != "name=cara;email=cara@home;role=cook;" or range2 != "" or range3 != "") {
        ! "range1=" + range1 + ":" + range2 + ":" + range3;
        ^ 5;
    }
    ? (range4 != "name=alice;email=alice@home;role=cook;|name=bob;email=bob@home;role=shop;") {
        ! "range4=" + range4;
        ^ 6;
    }
    ? (range5 != "name=alice;email=alice@home;role=cook;|name=bob;email=bob@home;role=shop;|name=cara;email=cara@home;role=cook;|name=drew;email=drew@home;role=clean;") {
        ! "range5=" + range5;
        ^ 7;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 8;
    }

    ! "ashdb range smoke ok";
    ^ 0;
}
