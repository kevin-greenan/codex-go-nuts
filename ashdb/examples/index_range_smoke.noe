& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: index_range_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_define_table(db, "users", 96, "name:text,email_key:i64!,role:text");

    row10 := "";
    row10 = row_append(row10, "name", "alice");
    row10 = row_append(row10, "email_key", "1001");
    row10 = row_append(row10, "role", "cook");

    row20 := "";
    row20 = row_append(row20, "name", "bob");
    row20 = row_append(row20, "email_key", "1002");
    row20 = row_append(row20, "role", "shop");

    row30 := "";
    row30 = row_append(row30, "name", "cara");
    row30 = row_append(row30, "email_key", "1003");
    row30 = row_append(row30, "role", "clean");

    row40 := "";
    row40 = row_append(row40, "name", "drew");
    row40 = row_append(row40, "email_key", "1004");
    row40 = row_append(row40, "role", "plan");

    ins0 := db_insert_row(db, "users", 10, row10);
    ins1 := db_insert_row(db, "users", 20, row20);
    ins2 := db_insert_row(db, "users", 30, row30);
    ins3 := db_insert_row(db, "users", 40, row40);

    range0 := db_scan_by_index_key_range_text(db, "users", "email_key", 1002, 1003, "|");
    range1 := db_scan_by_index_key_range_text(db, "users", "email_key", 1004, 1004, "|");
    range2 := db_scan_by_index_key_range_text(db, "users", "email_key", 2000, 3000, "|");
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    users_root1 := db_table_root(reopened, "users");
    range3 := db_scan_by_index_key_range_text(reopened, "users", "email_key", 1001, 1004, "|");
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root < 0 or users_root1 != users_root) {
        ! "root=" + text_of(users_root) + ":" + text_of(users_root1);
        ^ 2;
    }
    ? (ins0 < 0 or ins1 < 0 or ins2 < 0 or ins3 < 0) {
        ! "ins=" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(ins2) + ":" + text_of(ins3);
        ^ 3;
    }
    ? (range0 != "name=bob;email_key=1002;role=shop;|name=cara;email_key=1003;role=clean;") {
        ! "range0=" + range0;
        ^ 4;
    }
    ? (range1 != "name=drew;email_key=1004;role=plan;" or range2 != "") {
        ! "range1=" + range1 + ":" + range2;
        ^ 5;
    }
    ? (range3 != "name=alice;email_key=1001;role=cook;|name=bob;email_key=1002;role=shop;|name=cara;email_key=1003;role=clean;|name=drew;email_key=1004;role=plan;") {
        ! "range3=" + range3;
        ^ 6;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 7;
    }

    ! "ashdb index range smoke ok";
    ^ 0;
}
