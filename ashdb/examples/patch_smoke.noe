& "../lib/db.noe";

@user_row(name: text, email_key: text, role: text, active: text) -> text {
    payload := "";
    payload = row_append(payload, "name", name);
    payload = row_append(payload, "email_key", email_key);
    payload = row_append(payload, "role", role);
    payload = row_append(payload, "active", active);
    ^ payload;
}

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: patch_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 256);
    defined := db_define_table(db, "users", 96, "name:text,email_key:i64!,role:text,active:bool=false");
    inserted := db_insert_row(db, "users", 10, user_row("alice", "1001", "cook", "true"));

    patch0 := "";
    patch0 = row_append(patch0, "role", "planner");
    patched0 := db_patch_row(db, "users", 10, patch0);
    row0 := db_get(db, "users", 10);

    patch1 := "";
    patch1 = row_append(patch1, "active", "false");
    patch1 = row_append(patch1, "name", "alicia");
    patched1 := db_patch_by_unique_i64(db, "users", "email_key", 1001, patch1);
    row1 := db_get(db, "users", 10);

    bad_patch := "";
    bad_patch = row_append(bad_patch, "active", "maybe");
    patched_bad := db_patch_row(db, "users", 10, bad_patch);

    missing_patch := db_patch_row(db, "users", 99, patch0);
    missing_unique := db_patch_by_unique_i64(db, "users", "email_key", 9999, patch1);
    wrong_unique := db_patch_by_unique_i64(db, "users", "role", 1, patch1);
    validate0 := db_validate_report(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 256);
    row2 := db_get(reopened, "users", 10);
    validate1 := db_validate_report(reopened);
    closed1 := db_close(reopened);

    ? (defined <= 0 or inserted < 0) {
        ! "setup=" + text_of(defined) + ":" + text_of(inserted);
        ^ 2;
    }
    ? (patched0 < 0 or row_get(row0, "role") != "planner" or row_get(row0, "name") != "alice") {
        ! "patch0=" + text_of(patched0) + ":" + row0;
        ^ 3;
    }
    ? (patched1 < 0 or row_get(row1, "name") != "alicia" or row_get(row1, "active") != "false" or row_get(row1, "email_key") != "1001") {
        ! "patch1=" + text_of(patched1) + ":" + row1;
        ^ 4;
    }
    ? (patched_bad != -2 or missing_patch != -1 or missing_unique != -1 or wrong_unique != -3) {
        ! "errs=" + text_of(patched_bad) + ":" + text_of(missing_patch) + ":" + text_of(missing_unique) + ":" + text_of(wrong_unique);
        ^ 5;
    }
    ? (validate0 != "ok" or row_get(row2, "role") != "planner" or row_get(row2, "name") != "alicia" or row_get(row2, "active") != "false" or validate1 != "ok" or not closed0 or not closed1) {
        ! "reopen=" + validate0 + ":" + row2 + ":" + validate1;
        ^ 6;
    }

    ! "ashdb patch smoke ok";
    ^ 0;
}
