& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: index_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_create_table(db, "users", 20);
    email_index := db_create_index(db, "users", "email");
    dup_index := db_create_index(db, "users", "email");
    user0 := db_insert(db, "users", 10, "alice");
    user1 := db_insert(db, "users", 20, "bob");
    idx0 := db_index_put(db, "users", "email", 1001, 10);
    idx1 := db_index_put(db, "users", "email", 1002, 20);
    idx2 := db_index_put(db, "users", "email", 1002, 30);
    found0 := db_index_get(db, "users", "email", 1001);
    found1 := db_index_get(db, "users", "email", 1002);
    found_missing := db_index_get(db, "users", "email", 9999);
    deleted := db_index_delete(db, "users", "email", 1001);
    found_deleted := db_index_get(db, "users", "email", 1001);
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    users_root1 := db_table_root(reopened, "users");
    email_index1 := db_table_root(reopened, "idx.users.email");
    found_again := db_index_get(reopened, "users", "email", 1002);
    scan_index := db_scan_text(reopened, "idx.users.email", "|");
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root != 2 or email_index != 3 or dup_index != -2) {
        ! "roots=" + text_of(users_root) + ":" + text_of(email_index) + ":" + text_of(dup_index);
        ^ 2;
    }
    ? (user0 < 0 or user1 < 0) {
        ! "users=" + text_of(user0) + ":" + text_of(user1);
        ^ 3;
    }
    ? (idx0 < 0 or idx1 < 0 or idx2 < 0) {
        ! "index_put=" + text_of(idx0) + ":" + text_of(idx1) + ":" + text_of(idx2);
        ^ 4;
    }
    ? (found0 != 10 or found1 != 30 or found_missing != -1) {
        ! "found=" + text_of(found0) + ":" + text_of(found1) + ":" + text_of(found_missing);
        ^ 5;
    }
    ? (deleted < 0 or found_deleted != -1) {
        ! "delete=" + text_of(deleted) + ":" + text_of(found_deleted);
        ^ 6;
    }
    ? (users_root1 != 2 or email_index1 != 3) {
        ! "roots1=" + text_of(users_root1) + ":" + text_of(email_index1);
        ^ 7;
    }
    ? (found_again != 30) {
        ! "again=" + text_of(found_again);
        ^ 8;
    }
    ? (scan_index != "30.........") {
        ! "scan=" + scan_index;
        ^ 9;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 10;
    }

    ! "ashdb index smoke ok";
    ^ 0;
}
