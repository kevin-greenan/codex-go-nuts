& "../lib/db.noe";

@wrap_i64(value: i64, limit: i64) -> i64 {
    out := value;
    ~ (out >= limit) {
        out = out - limit;
    }
    ^ out;
}

@user_payload(seq: i64) -> text {
    payload := "";
    payload = row_append(payload, "name", "user" + text_of(seq));
    payload = row_append(payload, "age", text_of(20 + wrap_i64(seq, 50)));
    payload = row_append(payload, "email_key", text_of(10000 + seq));
    payload = row_append(payload, "active", text_of(wrap_i64(seq, 2) == 0));
    ^ payload;
}

@user_patch(seq: i64) -> text {
    payload := "";
    payload = row_append(payload, "age", text_of(100 + wrap_i64(seq, 30)));
    payload = row_append(payload, "active", "true");
    ^ payload;
}

@key_count(db: DB, table_name: text) -> i64 {
    key := db_first_key(db, table_name);
    total := 0;
    ~ (key >= 0) {
        total = total + 1;
        key = db_next_key(db, table_name, key);
    }
    ^ total;
}

@verify_state(db: DB, present_limit: i64, deleted_limit: i64) -> bool {
    ? (db_validate_report(db) != "ok") {
        ^ false;
    }
    key := 1;
    ~ (key <= present_limit) {
        row0 := db_get(db, "users", key);
        ? (key <= deleted_limit) {
            ? (count(row0) != 0) {
                ^ false;
            }
        }
        ? (key > deleted_limit) {
            ? (row_get(row0, "email_key") != text_of(10000 + key)) {
                ^ false;
            }
        }
        key = key + 1;
    }
    ^ true;
}

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: reopen_regress_smoke <db-path>";
        ^ 1;
    }

    db0 := db_open(arg(1), 256);
    defined := db_define_table(db0, "users", 96, "name:text,age:i64,email_key:i64!,active:bool=false");
    committed0 := db_begin(db0);
    key := 1;
    ~ (key <= 120) {
        wrote := db_insert_row(db0, "users", key, user_payload(key));
        ? (wrote < 0) {
            ! "insert0=" + text_of(key) + ":" + text_of(wrote);
            ^ 2;
        }
        key = key + 1;
    }
    committed1 := db_commit(db0);
    closed0 := db_close(db0);

    db1 := db_open(arg(1), 256);
    ok1 := verify_state(db1, 120, 0);
    key = 10;
    ~ (key <= 90) {
        patched := db_patch_row(db1, "users", key, user_patch(key));
        ? (patched < 0) {
            ! "patch1=" + text_of(key) + ":" + text_of(patched);
            ^ 3;
        }
        key = key + 10;
    }
    tx1 := db_begin(db1);
    key = 121;
    ~ (key <= 150) {
        wrote := db_insert_row(db1, "users", key, user_payload(key));
        ? (wrote < 0) {
            ! "insert1=" + text_of(key) + ":" + text_of(wrote);
            ^ 4;
        }
        key = key + 1;
    }
    rollback1 := db_rollback(db1);
    ok2 := verify_state(db1, 120, 0);
    closed1 := db_close(db1);

    db2 := db_open(arg(1), 256);
    ok3 := verify_state(db2, 120, 0);
    tx2 := db_begin(db2);
    key = 1;
    ~ (key <= 30) {
        deleted := db_delete_row(db2, "users", key);
        ? (deleted < 0) {
            ! "delete2=" + text_of(key) + ":" + text_of(deleted);
            ^ 5;
        }
        key = key + 1;
    }
    committed2 := db_commit(db2);
    count2 := key_count(db2, "users");
    closed2 := db_close(db2);

    db3 := db_open(arg(1), 256);
    ok4 := verify_state(db3, 120, 30);
    count3 := key_count(db3, "users");
    row40 := db_get_result(db3, "users", 40);
    row10 := db_get_result(db3, "users", 10);
    range0 := db_scan_key_range_rows_text(db3, "users", 31, 35, "|");
    compacted := db_compact_table_with_indexes(db3, "users");
    ok5 := verify_state(db3, 120, 30);
    closed3 := db_close(db3);

    ? ((defined <= 0 and defined != -2) or not committed0 or not committed1 or not closed0) {
        ! "phase0=" + text_of(defined) + ":" + text_of(committed0) + ":" + text_of(committed1);
        ^ 6;
    }
    ? (not ok1 or not rollback1 or not ok2 or not closed1) {
        ! "phase1=" + text_of(ok1) + ":" + text_of(rollback1) + ":" + text_of(ok2);
        ^ 7;
    }
    ? (not ok3 or not tx2 or not committed2 or count2 != 90 or not closed2) {
        ! "phase2=" + text_of(ok3) + ":" + text_of(tx2) + ":" + text_of(committed2) + ":" + text_of(count2);
        ^ 8;
    }
    ? (not ok4 or count3 != 90 or row_get(row40, "found") != "true" or row_get(row40, "__key") != "40") {
        ! "phase3=" + text_of(ok4) + ":" + text_of(count3) + ":" + row40;
        ^ 9;
    }
    ? (row_get(row10, "found") != "false" or find(range0, "__key=31") < 0 or compacted < 0 or not ok5 or not closed3) {
        ! "phase4=" + row10 + ":" + range0 + ":" + text_of(compacted) + ":" + text_of(ok5);
        ^ 10;
    }

    ! "ashdb reopen regress smoke ok";
    ^ 0;
}
