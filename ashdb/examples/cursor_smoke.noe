& "../lib/db.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: cursor_smoke <db-path>";
        ^ 1;
    }

    db := db_open(arg(1), 128);
    users_root := db_define_table(db, "users", 96, "name:text,role:text");

    row10 := "";
    row10 = row_append(row10, "name", "alice");
    row10 = row_append(row10, "role", "cook");

    row25 := "";
    row25 = row_append(row25, "name", "bob");
    row25 = row_append(row25, "role", "shop");

    row40 := "";
    row40 = row_append(row40, "name", "cara");
    row40 = row_append(row40, "role", "clean");

    row55 := "";
    row55 = row_append(row55, "name", "drew");
    row55 = row_append(row55, "role", "plan");

    ins0 := db_insert_row(db, "users", 10, row10);
    ins1 := db_insert_row(db, "users", 25, row25);
    ins2 := db_insert_row(db, "users", 40, row40);
    ins3 := db_insert_row(db, "users", 55, row55);

    cursor0 := db_cursor_open(db, "users");
    keys0 := "";
    rows0 := "";
    idx := 0;
    ~ (idx < 5) {
        ? (count(keys0) > 0) {
            keys0 = keys0 + ":";
        }
        keys0 = keys0 + text_of(db_cursor_key(cursor0));
        row0 := db_cursor_result_row(db, cursor0);
        ? (count(rows0) > 0) {
            rows0 = rows0 + "|";
        }
        rows0 = rows0 + row0;
        cursor0 = db_cursor_next(db, cursor0);
        idx = idx + 1;
    }
    seek0 := db_cursor_key(db_cursor_open_at_or_after(db, "users", 26));
    seek1 := db_cursor_key(db_cursor_seek_key(db, db_cursor_open(db, "users"), 40));
    synced0 := db_sync(db);
    closed0 := db_close(db);

    reopened := db_open(arg(1), 128);
    users_root1 := db_table_root(reopened, "users");
    first1 := db_cursor_key(db_cursor_open(reopened, "users"));
    seek2 := db_cursor_key(db_cursor_open_at_or_after(reopened, "users", 25));
    next1 := db_cursor_key(db_cursor_next(reopened, db_cursor_open_at_or_after(reopened, "users", 25)));
    synced1 := db_sync(reopened);
    closed1 := db_close(reopened);

    ? (users_root < 0 or users_root1 != users_root) {
        ! "root=" + text_of(users_root) + ":" + text_of(users_root1);
        ^ 2;
    }
    ? (ins0 < 0 or ins1 < 0 or ins2 < 0 or ins3 < 0) {
        ! "ins=" + text_of(ins0) + ":" + text_of(ins1) + ":" + text_of(ins2) + ":" + text_of(ins3);
        ^ 3;
    }
    ? (keys0 != "10:25:40:55:-1") {
        ! "keys0=" + keys0;
        ^ 4;
    }
    ? (find(rows0, "name=alice;role=cook;__key=10;") < 0 or find(rows0, "name=bob;role=shop;__key=25;") < 0 or find(rows0, "name=cara;role=clean;__key=40;") < 0 or find(rows0, "name=drew;role=plan;__key=55;") < 0) {
        ! "rows0=" + rows0;
        ^ 5;
    }
    ? (seek0 != 40 or seek1 != 40 or first1 != 10 or seek2 != 25 or next1 != 40) {
        ! "keys1=" + text_of(seek0) + ":" + text_of(seek1) + ":" + text_of(first1) + ":" + text_of(seek2) + ":" + text_of(next1);
        ^ 6;
    }
    ? (not synced0 or not closed0 or not synced1 or not closed1) {
        ^ 7;
    }

    ! "ashdb cursor smoke ok";
    ^ 0;
}
