%Pair {
    left: i64;
    right: i64;
}

@sum(xs: list<i64>) -> i64 {
    idx := 0;
    total := 0;
    ~ (idx < count(xs)) {
        total = total + xs[idx];
        idx = idx + 1;
    }
    ^ total;
}

@main() -> i64 {
    pair := Pair { left: 21, right: 34 };
    xs :: list<i64> := [pair.left, pair.right];
    ys := append(xs, 55);
    ! sum(xs);
    ! ys[2];
    ! count(ys);
    ^ 0;
}
