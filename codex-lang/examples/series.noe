@sum_to(n: i64) -> i64 {
    total := 0;
    index := 1;
    ~ (index <= n) {
        total = total + index;
        index = index + 1;
    }
    ^ total;
}

@fib(n: i64) -> i64 {
    ? (n <= 1) {
        ^ n;
    }
    | {
        ^ fib(n - 1) + fib(n - 2);
    }
}

@main() -> i64 {
    ! sum_to(10);
    ! fib(10);
    ^ 0;
}
