@main() -> i64 {
    ? (arg_count() < 3) {
        ! "usage: text_pipeline <input-path> <output-path>";
        ^ 1;
    }

    source := read_text(arg(1));
    prefix := slice(source, 0, 5);
    marker := "bytes=" + text_of(count(source));
    ! marker;
    ! prefix;
    ok := write_text(arg(2), source + "selfhost");
    ? (not ok) {
        ^ 1;
    }
    ^ 0;
}
