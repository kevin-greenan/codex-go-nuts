loom main() -> i64:
    if arg_count() < 4:
        emit "usage: socket_probe <host> <port> <payload>";
        return 1;

    let host = arg(1);
    let port = i64_of(arg(2));
    let payload = arg(3);
    let sock = socket_open(host, port);
    let wrote = socket_send(sock, payload);
    let reply = socket_recv(sock, 4096);
    let closed = socket_close(sock);

    emit "wrote=" + text_of(wrote);
    emit reply;

    if not closed:
        emit "socket_close failed";
        return 1;

    return 0;
