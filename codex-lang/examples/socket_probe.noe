@main() -> i64 {
    ? (arg_count() < 4) {
        ! "usage: socket_probe <host> <port> <payload>";
        ^ 1;
    }

    host := arg(1);
    port := i64_of(arg(2));
    payload := arg(3);
    sock := socket_open(host, port);
    wrote := socket_send(sock, payload);
    reply := socket_recv(sock, 4096);
    closed := socket_close(sock);

    ! "wrote=" + text_of(wrote);
    ! reply;

    ? (not closed) {
        ! "socket_close failed";
        ^ 1;
    }

    ^ 0;
}
