& "../lib/server.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: cookie_server <port>";
        ^ 1;
    }

    port := i64_of(arg(1));
    server := kiln_server_receive_once(port, 4096);
    request := server.request;

    body := "session=" + kiln_http_cookie_value(request.headers, "session");
    body = body + ";theme=" + kiln_http_cookie_value(request.headers, "theme");
    body = body + ";tags=" + kiln_http_header_values(request.headers, "X-Tag");

    ? (request.version != "HTTP/1.1") {
        ^ 2;
    }
    finished := kiln_server_finish_reply(server, kiln_reply_text(200, body));
    ? (not finished) {
        ^ 3;
    }
    ^ 0;
}
