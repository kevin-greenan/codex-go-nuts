& "../lib/http.noe";

@main() -> i64 {
    ? (arg_count() < 2) {
        ! "usage: form_server <port>";
        ^ 1;
    }

    port := i64_of(arg(1));
    listener := listener_open(port);
    conn := listener_accept(listener);
    raw := socket_recv(conn, 4096);
    request := kiln_http_parse_request(raw);

    body := "path=" + kiln_http_path_only(request.path);
    body = body + ";query_name=" + kiln_http_query_value(request.path, "name");
    body = body + ";form_name=" + kiln_http_form_value(request, "name");
    body = body + ";form_note=" + kiln_http_form_value(request, "note");

    response := kiln_http_text(200, body);
    wrote := socket_send(conn, response);
    closed_conn := socket_close(conn);
    closed_listener := listener_close(listener);

    ? (wrote <= 0) {
        ^ 2;
    }
    ? (not closed_conn or not closed_listener) {
        ^ 3;
    }
    ? (request.version != "HTTP/1.1") {
        ^ 4;
    }
    ^ 0;
}
