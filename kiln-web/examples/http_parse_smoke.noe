& "../lib/http.noe";

@main() -> i64 {
    raw := "POST /submit?ok=1&name=ada+lovelace HTTP/1.1\r\nHost: localhost\r\nContent-Type: application/x-www-form-urlencoded\r\n\r\nname=ada+lovelace&role=math%20pioneer";
    request := kiln_http_parse_request(raw);
    ? (request.method != "POST") {
        ! "method mismatch";
        ^ 1;
    }
    ? (request.path != "/submit?ok=1&name=ada+lovelace") {
        ! "path mismatch";
        ^ 2;
    }
    ? (request.version != "HTTP/1.1") {
        ! "version mismatch";
        ^ 3;
    }
    ? (kiln_http_header_value(request.headers, "Host") != "localhost") {
        ! "host mismatch";
        ^ 4;
    }
    ? (kiln_http_header_value(request.headers, "Content-Type") != "application/x-www-form-urlencoded") {
        ! "content-type mismatch";
        ^ 5;
    }
    ? (request.body != "name=ada+lovelace&role=math%20pioneer") {
        ! "body mismatch";
        ^ 6;
    }
    ? (kiln_http_path_only(request.path) != "/submit") {
        ! "path-only mismatch";
        ^ 10;
    }
    ? (kiln_http_query_value(request.path, "ok") != "1") {
        ! "query ok mismatch";
        ^ 11;
    }
    ? (kiln_http_query_value(request.path, "name") != "ada lovelace") {
        ! "query name mismatch";
        ^ 12;
    }
    ? (kiln_http_form_value(request, "name") != "ada lovelace") {
        ! "form name mismatch";
        ^ 13;
    }
    ? (kiln_http_form_value(request, "role") != "math pioneer") {
        ! "form role mismatch";
        ^ 14;
    }

    response := kiln_http_text(200, "ok");
    ? (find(response, "HTTP/1.1 200 OK") < 0) {
        ! "status mismatch";
        ^ 7;
    }
    ? (find(response, "Content-Length: 2") < 0) {
        ! "length mismatch";
        ^ 8;
    }
    ? (find(response, "\r\n\r\nok") < 0) {
        ! "body serialization mismatch";
        ^ 9;
    }

    ! "kiln http parse smoke ok";
    ^ 0;
}
