& "../lib/http.noe";
& "../lib/html.noe";

@main() -> i64 {
    card := kiln_html_div(kiln_html_attr("class", "card"), kiln_html_heading1("Kiln <Home>") + kiln_html_paragraph("safe & steady"));
    links :: list<text> := [
        kiln_html_link("/", "Home"),
        kiln_html_link("/users/42", "User 42")
    ];
    form := kiln_html_form("post", "/notes", kiln_html_field("Name", "name", kiln_html_input_text("name", "Ada")) + kiln_html_field("Notes", "note", kiln_html_textarea("note", "Math & logic")) + kiln_html_button("Save"));
    body := card + kiln_html_unordered_list(links) + form;
    page := kiln_html_page_with_head("Kiln", kiln_html_stylesheet("/assets/site.css"), kiln_html_section(kiln_html_attr("class", "hero"), kiln_html_heading1("Kiln") + kiln_html_paragraph("tiny renderer")) + kiln_html_tag("main", "", body));
    response := kiln_http_response(200, "text/html; charset=utf-8", page);

    ? (find(page, "<!doctype html>") != 0) {
        ! "doctype mismatch";
        ^ 1;
    }
    ? (find(page, "&lt;Home&gt;") < 0) {
        ! "escape mismatch";
        ^ 2;
    }
    ? (find(page, "&amp;") < 0) {
        ! "amp mismatch";
        ^ 3;
    }
    ? (find(page, "<ul>") < 0 or find(page, "</ul>") < 0) {
        ! "list mismatch";
        ^ 4;
    }
    ? (find(page, "<form method=\"post\" action=\"/notes\">") < 0) {
        ! "form mismatch";
        ^ 7;
    }
    ? (find(page, "Math &amp; logic") < 0) {
        ! "textarea escape mismatch";
        ^ 8;
    }
    ? (find(page, "<link rel=\"stylesheet\" href=\"/assets/site.css\">") < 0) {
        ! "stylesheet mismatch";
        ^ 9;
    }
    ? (find(response, "Content-Type: text/html; charset=utf-8") < 0) {
        ! "response content-type mismatch";
        ^ 5;
    }
    ? (find(response, "<title>Kiln</title>") < 0) {
        ! "title mismatch";
        ^ 6;
    }

    ! "kiln html smoke ok";
    ^ 0;
}
