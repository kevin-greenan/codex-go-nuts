& "server.noe";

%KilnAppRouteReply {
    route_name: text;
    reply: KilnReply;
}

%KilnAppRouteAsset {
    route_name: text;
    file_path: text;
    content_type: text;
}

%KilnStaticApp {
    app: KilnApp;
    replies: list<KilnAppRouteReply>;
}

%KilnStaticAssetApp {
    site: KilnStaticApp;
    assets: list<KilnAppRouteAsset>;
}

@kiln_app_route_reply(route_name: text, reply: KilnReply) -> KilnAppRouteReply {
    ^ KilnAppRouteReply { route_name: route_name, reply: reply };
}

@kiln_app_route_asset(route_name: text, file_path: text, content_type: text) -> KilnAppRouteAsset {
    ^ KilnAppRouteAsset { route_name: route_name, file_path: file_path, content_type: content_type };
}

@kiln_static_app(routes: list<KilnRoute>, replies: list<KilnAppRouteReply>, read_limit: i64) -> KilnStaticApp {
    ^ KilnStaticApp { app: kiln_app(routes, read_limit), replies: replies };
}

@kiln_asset_content_type(path: text) -> text {
    ? (find(path, ".css") == count(path) - 4) {
        ^ "text/css; charset=utf-8";
    }
    ? (find(path, ".js") == count(path) - 3) {
        ^ "text/javascript; charset=utf-8";
    }
    ? (find(path, ".html") == count(path) - 5) {
        ^ "text/html; charset=utf-8";
    }
    ? (find(path, ".json") == count(path) - 5) {
        ^ "application/json; charset=utf-8";
    }
    ? (find(path, ".svg") == count(path) - 4) {
        ^ "image/svg+xml";
    }
    ^ "text/plain; charset=utf-8";
}

@kiln_reply_file(status: i64, file_path: text, content_type: text) -> KilnReply {
    handle := file_open(file_path);
    size0 := file_size(handle);
    body := file_read(handle, 0, size0);
    closed := file_close(handle);
    ? (not closed) {
        ^ kiln_reply_text(500, "asset close failed");
    }
    ^ kiln_reply(status, content_type, body);
}

@kiln_static_asset_app(routes: list<KilnRoute>, replies: list<KilnAppRouteReply>, assets: list<KilnAppRouteAsset>, read_limit: i64) -> KilnStaticAssetApp {
    ^ KilnStaticAssetApp { site: kiln_static_app(routes, replies, read_limit), assets: assets };
}

@kiln_static_app_reply(site: KilnStaticApp, dispatch: KilnDispatch) -> KilnReply {
    idx := 0;
    ~ (idx < count(site.replies)) {
        entry := site.replies[idx];
        ? (kiln_dispatch_is(dispatch, entry.route_name)) {
            ^ entry.reply;
        }
        idx = idx + 1;
    }
    ^ kiln_dispatch_fallback_text(dispatch);
}

@kiln_static_app_receive_once(site: KilnStaticApp, port: i64) -> KilnAppRequest {
    ^ kiln_app_receive_once(site.app, port);
}

@kiln_static_app_finish_reply(req: KilnAppRequest, reply: KilnReply) -> bool {
    ^ kiln_app_finish_reply(req, reply);
}

@kiln_static_asset_app_reply(site: KilnStaticAssetApp, dispatch: KilnDispatch) -> KilnReply {
    reply := kiln_static_app_reply(site.site, dispatch);
    ? (reply.status != 404 and reply.status != 405) {
        ^ reply;
    }

    idx := 0;
    ~ (idx < count(site.assets)) {
        entry := site.assets[idx];
        ? (kiln_dispatch_is(dispatch, entry.route_name)) {
            ^ kiln_reply_file(200, entry.file_path, entry.content_type);
        }
        idx = idx + 1;
    }
    ^ reply;
}

@kiln_static_asset_app_receive_once(site: KilnStaticAssetApp, port: i64) -> KilnAppRequest {
    ^ kiln_static_app_receive_once(site.site, port);
}

@kiln_static_asset_app_finish_reply(req: KilnAppRequest, reply: KilnReply) -> bool {
    ^ kiln_static_app_finish_reply(req, reply);
}
