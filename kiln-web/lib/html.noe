@kiln_html_escape(text: text) -> text {
    out := "";
    idx := 0;
    ~ (idx < count(text)) {
        ch := slice(text, idx, 1);
        ? (ch == "&") {
            out = out + "&amp;";
        }
        | {
            ? (ch == "<") {
                out = out + "&lt;";
            }
            | {
                ? (ch == ">") {
                    out = out + "&gt;";
                }
                | {
                    ? (ch == "\"") {
                        out = out + "&quot;";
                    }
                    | {
                        out = out + ch;
                    }
                }
            }
        }
        idx = idx + 1;
    }
    ^ out;
}

@kiln_html_attr(name: text, value: text) -> text {
    ^ " " + name + "=\"" + kiln_html_escape(value) + "\"";
}

@kiln_html_tag(name: text, attrs: text, body: text) -> text {
    ^ "<" + name + attrs + ">" + body + "</" + name + ">";
}

@kiln_html_empty_tag(name: text, attrs: text) -> text {
    ^ "<" + name + attrs + ">";
}

@kiln_html_text(text: text) -> text {
    ^ kiln_html_escape(text);
}

@kiln_html_link(href: text, label: text) -> text {
    ^ kiln_html_tag("a", kiln_html_attr("href", href), kiln_html_text(label));
}

@kiln_html_stylesheet(href: text) -> text {
    attrs := kiln_html_attr("rel", "stylesheet") + kiln_html_attr("href", href);
    ^ kiln_html_empty_tag("link", attrs);
}

@kiln_html_div(attrs: text, body: text) -> text {
    ^ kiln_html_tag("div", attrs, body);
}

@kiln_html_section(attrs: text, body: text) -> text {
    ^ kiln_html_tag("section", attrs, body);
}

@kiln_html_heading1(text: text) -> text {
    ^ kiln_html_tag("h1", "", kiln_html_text(text));
}

@kiln_html_paragraph(text: text) -> text {
    ^ kiln_html_tag("p", "", kiln_html_text(text));
}

@kiln_html_list_item(body: text) -> text {
    ^ kiln_html_tag("li", "", body);
}

@kiln_html_unordered_list(items: list<text>) -> text {
    out := "";
    idx := 0;
    ~ (idx < count(items)) {
        out = out + kiln_html_list_item(items[idx]);
        idx = idx + 1;
    }
    ^ kiln_html_tag("ul", "", out);
}

@kiln_html_label(for_id: text, text: text) -> text {
    ^ kiln_html_tag("label", kiln_html_attr("for", for_id), kiln_html_text(text));
}

@kiln_html_input_text(name: text, value: text) -> text {
    attrs := kiln_html_attr("type", "text") + kiln_html_attr("name", name) + kiln_html_attr("value", value);
    ^ kiln_html_empty_tag("input", attrs);
}

@kiln_html_textarea(name: text, value: text) -> text {
    ^ kiln_html_tag("textarea", kiln_html_attr("name", name), kiln_html_text(value));
}

@kiln_html_button(label: text) -> text {
    ^ kiln_html_tag("button", kiln_html_attr("type", "submit"), kiln_html_text(label));
}

@kiln_html_form(method: text, action: text, body: text) -> text {
    attrs := kiln_html_attr("method", method) + kiln_html_attr("action", action);
    ^ kiln_html_tag("form", attrs, body);
}

@kiln_html_field(label: text, input_id: text, control: text) -> text {
    field_body := kiln_html_label(input_id, label) + control;
    ^ kiln_html_div(kiln_html_attr("class", "field"), field_body);
}

@kiln_html_page_shell(title: text, intro: text, body: text) -> text {
    hero := kiln_html_section(kiln_html_attr("class", "hero"), kiln_html_heading1(title) + kiln_html_paragraph(intro));
    main := kiln_html_tag("main", "", body);
    ^ kiln_html_page(title, hero + main);
}

@kiln_html_page_with_head(title: text, head_extra: text, body: text) -> text {
    head := kiln_html_tag("head", "", kiln_html_tag("meta", kiln_html_attr("charset", "utf-8"), "") + kiln_html_tag("title", "", kiln_html_text(title)) + head_extra);
    doc_body := kiln_html_tag("body", "", body);
    ^ "<!doctype html>" + kiln_html_tag("html", "", head + doc_body);
}

@kiln_html_page(title: text, body: text) -> text {
    ^ kiln_html_page_with_head(title, "", body);
}
