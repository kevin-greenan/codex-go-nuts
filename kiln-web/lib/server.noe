& "router.noe";

%KilnServeOnce {
    listener: listener;
    conn: socket;
    request: KilnHttpRequest;
}

%KilnApp {
    routes: list<KilnRoute>;
    read_limit: i64;
}

%KilnAppRequest {
    server: KilnServeOnce;
    dispatch: KilnDispatch;
}

@kiln_app(routes: list<KilnRoute>, read_limit: i64) -> KilnApp {
    ^ KilnApp { routes: routes, read_limit: read_limit };
}

@kiln_server_receive_once(port: i64, read_limit: i64) -> KilnServeOnce {
    listener0 := listener_open(port);
    conn0 := listener_accept(listener0);
    raw := socket_recv(conn0, read_limit);
    request0 := kiln_http_parse_request(raw);
    ^ KilnServeOnce { listener: listener0, conn: conn0, request: request0 };
}

@kiln_server_finish_response(server: KilnServeOnce, response: text) -> bool {
    wrote := socket_send(server.conn, response);
    closed_conn := socket_close(server.conn);
    closed_listener := listener_close(server.listener);
    ^ wrote > 0 and closed_conn and closed_listener;
}

@kiln_server_finish_reply(server: KilnServeOnce, reply: KilnReply) -> bool {
    ^ kiln_server_finish_response(server, kiln_reply_response(reply));
}

@kiln_app_receive_once(app: KilnApp, port: i64) -> KilnAppRequest {
    server := kiln_server_receive_once(port, app.read_limit);
    dispatch := kiln_dispatch(app.routes, server.request);
    ^ KilnAppRequest { server: server, dispatch: dispatch };
}

@kiln_app_finish_reply(request: KilnAppRequest, reply: KilnReply) -> bool {
    ^ kiln_server_finish_reply(request.server, reply);
}

@kiln_app_request(req: KilnAppRequest) -> KilnHttpRequest {
    ^ req.server.request;
}
