@hearthlight_recipes_page(db: DB, request: KilnHttpRequest) -> text {
    household := db_get(db, hearthlight_households_table(), 1);
    hero_copy := kiln_html_tag("div", kiln_html_attr("class", "hero-copy"), kiln_html_tag("p", kiln_html_attr("class", "eyebrow"), kiln_html_text("Kitchen Memory")) + kiln_html_tag("h1", "", kiln_html_text("Recipes")) + kiln_html_tag("p", kiln_html_attr("class", "hero-intro"), kiln_html_text("Build a small library of repeatable meals for " + row_get(household, "name") + ", then slot them into the week when energy is low.")));
    hero_stats := kiln_html_tag("div", kiln_html_attr("class", "hero-stats"), hearthlight_stat("Saved recipes", text_of(hearthlight_next_key(db, hearthlight_recipes_table()) - 1)) + hearthlight_stat("Pantry-friendly", "match scored") + hearthlight_stat("Planning flow", "Recipe → Week"));
    hero := kiln_html_tag("section", kiln_html_attr("class", "hero"), hero_copy + hero_stats);
    library := hearthlight_card("Recipe Library", hearthlight_recipe_library_html(db, true));
    form := hearthlight_card("Save A Recipe", hearthlight_recipe_form());
    layout := kiln_html_tag("div", kiln_html_attr("class", "planner-layout"), library + form);
    body := kiln_html_tag("div", kiln_html_attr("class", "shell"), hearthlight_nav(kiln_http_path_only(request.path)) + hero + hearthlight_flash_html(request) + layout);
    ^ kiln_html_page_with_head("Hearthlight Recipes", kiln_html_stylesheet("/assets/site.css"), body);
}

@hearthlight_setup_page(db: DB, request: KilnHttpRequest) -> text {
    household := db_get(db, hearthlight_households_table(), 1);
    hero_copy := kiln_html_tag("div", kiln_html_attr("class", "hero-copy"), kiln_html_tag("p", kiln_html_attr("class", "eyebrow"), kiln_html_text("Household Setup")) + kiln_html_tag("h1", "", kiln_html_text("Settings")) + kiln_html_tag("p", kiln_html_attr("class", "hero-intro"), kiln_html_text("Shape Hearthlight around " + row_get(household, "name") + " by adjusting the weekly rhythm and household roster.")));
    hero_stats := kiln_html_tag("div", kiln_html_attr("class", "hero-stats"), hearthlight_stat("Members", text_of(hearthlight_next_key(db, hearthlight_members_table()) - 1)) + hearthlight_stat("Planning day", row_get(household, "planning_day")) + hearthlight_stat("Shopping day", row_get(household, "shopping_day")));
    hero := kiln_html_tag("section", kiln_html_attr("class", "hero"), hero_copy + hero_stats);
    household_card := hearthlight_card("Household Rhythm", hearthlight_household_form(db));
    member_card := hearthlight_card("Add Member", hearthlight_member_form());
    roster_card := hearthlight_card("Household Roster", hearthlight_members_html(db));
    layout := kiln_html_tag("div", kiln_html_attr("class", "planner-layout"), household_card + kiln_html_tag("div", kiln_html_attr("class", "stack"), member_card + roster_card));
    body := kiln_html_tag("div", kiln_html_attr("class", "shell"), hearthlight_nav(kiln_http_path_only(request.path)) + hero + hearthlight_flash_html(request) + layout);
    ^ kiln_html_page_with_head("Hearthlight Setup", kiln_html_stylesheet("/assets/site.css"), body);
}
